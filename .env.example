# ──────────────────────────────────────────────────────────────────────────
# Open Managed Agents — Environment Variables Reference
# ──────────────────────────────────────────────────────────────────────────
# Copy this to .env and fill in values.
#
# Which secrets go where:
#   node scripts/sync-secrets.mjs --to main          # oma-managed-agents
#   node scripts/sync-secrets.mjs --to agent         # oma-sandbox-default
#   node scripts/sync-secrets.mjs --to integrations  # oma-managed-agents-integrations
#   node scripts/sync-secrets.mjs --to github        # GitHub Actions CI
#   node scripts/sync-secrets.mjs                    # all targets
# ──────────────────────────────────────────────────────────────────────────


# ─── CLOUDFLARE DEPLOY CREDENTIALS ───────────────────────────────────────
# Used by `wrangler` and `gh` CLI tools. Pushed to GitHub Actions repo
# secrets for CI/CD (not pushed to workers).

CLOUDFLARE_API_TOKEN=cfut_...
CLOUDFLARE_ACCOUNT_ID=<your-account-id>
CLOUDFLARE_ZONE_ID=<your-zone-id>

# npm publish token (for publishing @duyet/oma-cli, @duyet/oma-sdk)
# NPM_TOKEN=npm_...


# ─── REQUIRED — ALL THREE WORKERS ────────────────────────────────────────
# These must be set on every worker because each touches encrypted data.

# At-rest encryption key for credentials.auth, model_cards.api_key_cipher,
# and integration OAuth tokens. The worker refuses to boot without it.
# Generate with:  openssl rand -base64 32
# **BACK THIS UP** — losing it makes every encrypted row unreadable.
# Targets: main, agent, integrations
PLATFORM_ROOT_SECRET=


# ─── WORKER: oma-managed-agents (main API + Console) ────────────────────
# Route: app.oma.duyet.net
# Deploy: wrangler deploy --config apps/main/wrangler.jsonc --env production
# Sync:   node scripts/sync-secrets.mjs --to main

# better-auth session signing key. Sessions don't survive restart without it.
# Generate with:  openssl rand -hex 32
BETTER_AUTH_SECRET=

# Public origin for social OAuth redirect callbacks. Without this, better-auth
# on Cloudflare Workers defaults to a local URL and GitHub OAuth returns 500.
# Must match the custom domain the worker is deployed to.
BETTER_AUTH_URL=https://app.oma.duyet.net

# Bootstrap API key for the REST API. Used by the CLI (`oma`) and initial
# setup. In production, create per-tenant API keys from the Console instead.
# Generate with:  openssl rand -hex 24
API_KEY=

# Shared secret that gats /v1/internal/* endpoints between main worker and
# the integrations gateway. Must match on BOTH workers.
# Generate with:  openssl rand -base64 32
INTEGRATIONS_INTERNAL_SECRET=

# GitHub OAuth — for "Continue with GitHub" login on the Console.
# Create your own OAuth App at: github.com/settings/developers
# Callback URL: ${BETTER_AUTH_URL}/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth — optional, for "Continue with Google" on the Console.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=


# ─── WORKER: oma-sandbox-default (agent / sandbox / harness) ────────────
# Deploy: wrangler deploy --config apps/agent/wrangler.jsonc --env production
# Sync:   node scripts/sync-secrets.mjs --to agent

# PLATFORM_ROOT_SECRET (see above — also required here for vault/model-card
# decryption during sandbox warmup).

# Fallback LLM credential used when a tenant has not added a Model Card.
# In production, add a Model Card per tenant from the Console instead —
# keys are encrypted at rest under PLATFORM_ROOT_SECRET, scoped to the
# tenant, and rotatable without redeploy.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Alternative LLM gateway (AnyRouter). Only consulted when ANTHROPIC_API_KEY
# is unset.
# ANYROUTER_API_KEY=...

# Claude Code SDK auth (for claude-agent-sdk harness). Only consulted when
# ANTHROPIC_API_KEY is unset. Mint via:  claude setup-token
# CLAUDE_CODE_OAUTH_TOKEN=...

# Cap model output tokens for the harness.
# OMA_MAX_OUTPUT_TOKENS=4096


# ─── WORKER: oma-managed-agents-integrations (webhook / OAuth gateway) ──
# Route: integrations.oma.duyet.net
# Deploy: wrangler deploy --config apps/integrations/wrangler.jsonc --env production
# Sync:   node scripts/sync-secrets.mjs --to integrations

# PLATFORM_ROOT_SECRET (see above — also required here for OAuth token
# decryption at rest).
# INTEGRATIONS_INTERNAL_SECRET (must match the value on the main worker).

# GitHub OAuth creds (needed for GitHub App manifest flow callbacks).
# GITHUB_CLIENT_ID=...
# GITHUB_CLIENT_SECRET=...

# Optional: override the GitHub MCP server URL. Defaults to the GitHub-
# hosted MCP at https://api.githubcopilot.com/mcp/.
# GITHUB_MCP_URL=https://github-mcp.internal/


# ─── CLI ─────────────────────────────────────────────────────────────────
# These are NOT pushed to workers. They're read by the `oma` CLI when you
# run it locally (e.g., `oma session create`).

# API base URL and key for the CLI. OMA_API_KEY is typically the same value
# as API_KEY above (or a separate per-tenant key minted via Console/CLI).
OMA_BASE_URL=https://app.oma.duyet.net
OMA_API_KEY=


# ─── OAUTH PROVIDER CREDENTIALS (integrations) ──────────────────────────
# These are stored encrypted under PLATFORM_ROOT_SECRET in the database,
# not as wrangler secrets. The env vars below are used by the self-host
# Docker Compose path (apps/oma-vault). Cloudflare production uses the
# Console's OAuth wizard instead.
#
# LINEAR_OAUTH_CLIENT_ID=
# LINEAR_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# SLACK_OAUTH_CLIENT_ID=
# SLACK_OAUTH_CLIENT_SECRET=
# FEISHU_OAUTH_CLIENT_ID=
# FEISHU_OAUTH_CLIENT_SECRET=
# LARK_OAUTH_CLIENT_ID=
# LARK_OAUTH_CLIENT_SECRET=
# ASANA_OAUTH_CLIENT_ID=
# ASANA_OAUTH_CLIENT_SECRET=
# CLICKUP_OAUTH_CLIENT_ID=
# CLICKUP_OAUTH_CLIENT_SECRET=


# ─── SANDBOX PROVIDERS (self-host only) ─────────────────────────────────
# Cloudflare production uses the built-in Cloudflare Sandbox (Containers).
# These are only relevant for self-host / Docker Compose deployments.
#
# SANDBOX_PROVIDER=subprocess
# DAYTONA_API_KEY=
# DAYTONA_API_URL=
# E2B_API_KEY=
# SANDBOX_IMAGE=node:22-slim
# LITEBOX_MEMORY_MIB=512
# LITEBOX_CPUS=2


# ─── MONITORING ──────────────────────────────────────────────────────────
#
# Healthchecks.io ping URL for cron job monitoring. When set, OMA sends
# start/success/failure HTTP pings to healthchecks.io for every cron job
# tick (eval-tick, memory-retention, webhook-events-retention, dream-recovery
# on the main worker; linear-dispatch on the integrations gateway).
#
# Get your ping URL from https://healthchecks.io:
#   UUID format: https://hc-ping.com/<uuid>
#   Slug format: https://hc-ping.com/<ping-key>/<slug>
#
# Targets: main, integrations
# HEALTHCHECKS_IO_URL=https://hc-ping.com/your-uuid-here


# ─── MEMORY BUCKET (self-host S3-compatible) ────────────────────────────
# Only needed for remote sandbox backends (daytona / e2b).
# Cloudflare production uses R2 via worker bindings.
#
# MEMORY_S3_ENDPOINT=https://s3.us-west-2.amazonaws.com
# MEMORY_S3_ACCESS_KEY=
# MEMORY_S3_SECRET_KEY=
# MEMORY_S3_BUCKET=oma-memory
