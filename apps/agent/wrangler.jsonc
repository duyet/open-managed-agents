{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "oma-sandbox-default",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-13",
  "compatibility_flags": ["nodejs_compat"],

  // ─────────────────────────────────────────────────────────────────────
  // SELF-HOST BASELINE (sandbox/agent worker)
  // ─────────────────────────────────────────────────────────────────────
  // Top-level config = single-D1 self-host shape. oma.duyet.net's launch
  // env.production overlay below uses the SAME single-D1 shape (only
  // MAIN_DB bound) — sharding is premature with zero users; see that
  // overlay's own comment for how to scale out later.
  // ─────────────────────────────────────────────────────────────────────

  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile.sandbox",
      "instance_type": "lite",
      "max_instances": 50
    }
  ],

  "durable_objects": {
    "bindings": [
      { "name": "SESSION_DO", "class_name": "SessionDO" },
      { "name": "SANDBOX", "class_name": "Sandbox" },
      // Cross-script DO binding for RuntimeRoom. The class lives in the main
      // worker (apps/main/wrangler.jsonc), but DOs are namespace-level and
      // any worker in the account can bind the same class via `script_name`.
      // AcpProxyHarness uses this to attach to the daemon's RuntimeRoom
      // directly, no service-binding hop through main and no shared secret —
      // see apps/agent/src/harness/acp-proxy-loop.ts.
      { "name": "RUNTIME_ROOM", "class_name": "RuntimeRoom", "script_name": "oma-managed-agents" }
    ]
  },

  "kv_namespaces": [
    { "binding": "CONFIG_KV", "id": "<set-by-setup-cf-sh>" }
  ],

  // D1 layout — single-D1 self-host baseline. Same auto-detection as
  // apps/main/wrangler.jsonc: when AUTH_DB_01 isn't bound, the shared
  // MemoryStoreService resolves every tenant to MAIN_DB.
  "d1_databases": [
    { "binding": "MAIN_DB", "database_name": "oma-auth", "database_id": "<set-by-setup-cf-sh>" }
  ],

  // Service bindings:
  //
  // - INTEGRATIONS: integrations gateway. Used by the outbound proxy to
  //   refresh short-lived upstream tokens (e.g. GitHub installation tokens,
  //   ~1hr TTL) on 401. The agent worker never sees provider secrets directly
  //   — it just asks the gateway "please refresh credential X" and the gateway
  //   does the App-JWT signing using its locally-held private key.
  //
  // - MAIN_MCP: WorkerEntrypoint RPC into the main worker for MCP forwarding
  //   (cloud agent path). Per-request the DO calls
  //   `env.MAIN_MCP.mcpForward({tenantId, sessionId, serverName, ...})` and
  //   the main worker (where vault credentials already live) does the cred
  //   lookup + token injection + upstream call. The agent's DO never holds
  //   plaintext credentials — mirrors Anthropic Managed Agents' "credential
  //   proxy outside the harness" design. See apps/main/src/index.ts:McpProxyRpc
  //   for the entrypoint, packages/binding-mcp-transport for the AI-SDK
  //   transport adapter.
  //
  // Empty here because this is the self-host baseline — self-host uses the
  // oma-vault sidecar for credential injection instead of these service
  // bindings. The bindings themselves are wired below, in the hosted
  // overlay configs (env.production / env.staging), where the
  // INTEGRATIONS and oma-managed-agents (MAIN_MCP) workers actually exist.
  "services": [],

  // Workers AI for generating embeddings
  "ai": { "binding": "AI" },

  // Cloudflare Dynamic Workers (Worker Loader binding) — powers the opt-in
  // `run_dynamic_worker` "Code Mode" tool: spin up an ephemeral V8 isolate to
  // execute untrusted JS/Python and return the result. Requires the account
  // entitlement (open beta). Absent binding ⇒ tool omitted, so removing this
  // line degrades cleanly rather than crashing.
  "worker_loaders": [
    { "binding": "LOADER" }
  ],

  // Resolved bucket names per env — sandbox.ts FUSE mode mounts via the
  // S3 API which takes the actual bucket name (not the binding name).
  // CLOUDFLARE_ACCOUNT_ID is required by sandbox SDK createBackup() to
  // mint R2 presigned URLs for the squashfs upload (production mode).
  // setup-cf.sh fills in the account id (or self-hoster sets it manually).
  "vars": {
    "MEMORY_BUCKET_NAME": "oma-managed-agents-memory",
    "WORKSPACE_BUCKET_NAME": "oma-managed-agents-workspace",
    "BACKUP_BUCKET_NAME": "oma-managed-agents-backups",
    "CLOUDFLARE_ACCOUNT_ID": "<set-by-setup-cf-sh>"
  },

  "r2_buckets": [
    { "binding": "WORKSPACE_BUCKET", "bucket_name": "oma-managed-agents-workspace" },
    { "binding": "FILES_BUCKET", "bucket_name": "oma-managed-agents-files" },
    // Required by @cloudflare/sandbox createBackup/restoreBackup. Holds
    // the squashfs archives the BaseSnapshotStrategy persists per env.
    // The SDK looks for the binding by the literal name BACKUP_BUCKET.
    { "binding": "BACKUP_BUCKET", "bucket_name": "oma-managed-agents-backups" },
    // Memory store content. Mounted into the sandbox per attached store via
    // sandbox.mountBucket(<bucket-name>, "/mnt/memory/<store_name>",
    //   { endpoint+credentials+provider:"r2", prefix: "/<store_id>/", readOnly })
    // Agent reads/writes via standard file tools; writes propagate to R2 then
    // feed the apps/main MEMORY queue consumer for D1 audit.
    { "binding": "MEMORY_BUCKET", "bucket_name": "oma-managed-agents-memory" }
  ],

  "browser": { "binding": "BROWSER" },

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SessionDO", "Sandbox"]
    }
  ],

  "limits": { "cpu_ms": 300000 },
  "observability": { "enabled": true },

  "analytics_engine_datasets": [
    { "binding": "ANALYTICS", "dataset": "oma_events" }
  ],

  // ─────────────────────────────────────────────────────────────────────
  // ENVIRONMENT OVERLAYS (hosted)
  // ─────────────────────────────────────────────────────────────────────
  "env": {
    "production": {
  "name": "oma-sandbox-default",
      "containers": [
        {
          "class_name": "Sandbox",
          "image": "./Dockerfile.sandbox",
          // basic — 0.5 vCPU, 1 GB RAM, larger image limit.
          // lite (256 MB, 2 GB image) is too tight for the Python + Node
          // sandbox image which needs ~2.5 GB after toolchain slimming.
          "instance_type": "basic",
          "max_instances": 50
        }
      ],
      "durable_objects": {
        "bindings": [
          { "name": "SESSION_DO", "class_name": "SessionDO" },
          { "name": "SANDBOX", "class_name": "Sandbox" },
          { "name": "RUNTIME_ROOM", "class_name": "RuntimeRoom", "script_name": "oma-managed-agents" }
        ]
      },
      "kv_namespaces": [
        { "binding": "CONFIG_KV", "id": "6adfd1b06ee6493981b4b818d3dd81ae" }
      ],
      // Single-D1 launch layout — matches the top-level baseline. Only MAIN_DB
      // is bound; buildCfTenantDbProvider() picks the non-sharded
      // CfSharedAuthDbProvider because AUTH_DB_01 is absent. Re-add the shard
      // bindings (see git history / env.staging) to scale out later.
      "d1_databases": [
        { "binding": "MAIN_DB", "database_name": "oma-auth", "database_id": "c0f61e65-4e87-4561-91b7-a590313259b8" }
      ],
      "services": [
        { "binding": "INTEGRATIONS", "service": "oma-managed-agents-integrations" },
        { "binding": "MAIN_MCP", "service": "oma-managed-agents", "entrypoint": "McpProxyRpc" }
      ],
      "ai": { "binding": "AI" },
      "worker_loaders": [
        { "binding": "LOADER" }
      ],
      "vars": {
        "MEMORY_BUCKET_NAME": "oma-managed-agents-memory",
        "WORKSPACE_BUCKET_NAME": "oma-managed-agents-workspace",
        "BACKUP_BUCKET_NAME": "oma-managed-agents-backups",
        "CLOUDFLARE_ACCOUNT_ID": "23050adb6c92e313643a29e1ba64c88a"
      },
      "r2_buckets": [
        { "binding": "WORKSPACE_BUCKET", "bucket_name": "oma-managed-agents-workspace" },
        { "binding": "FILES_BUCKET", "bucket_name": "oma-managed-agents-files" },
        { "binding": "BACKUP_BUCKET", "bucket_name": "oma-managed-agents-backups" },
        { "binding": "MEMORY_BUCKET", "bucket_name": "oma-managed-agents-memory" }
      ],
      "browser": { "binding": "BROWSER" },
      "limits": { "cpu_ms": 300000 },
      "observability": { "enabled": true },
      "analytics_engine_datasets": [
        { "binding": "ANALYTICS", "dataset": "oma_events" }
      ]
    },
    "staging": {
      "name": "oma-sandbox-default-staging",
      "containers": [
        {
          "class_name": "Sandbox",
          "image": "./Dockerfile.sandbox",
          "instance_type": "lite",
          "max_instances": 50
        }
      ],
      "services": [
        { "binding": "INTEGRATIONS", "service": "oma-managed-agents-integrations-staging" },
        { "binding": "MAIN_MCP", "service": "oma-managed-agents-staging", "entrypoint": "McpProxyRpc" }
      ],
      // Cross-script DO binding to staging RuntimeRoom (lives in
      // managed-agents-staging). Same shape as prod above.
      "durable_objects": {
        "bindings": [
          { "name": "SESSION_DO", "class_name": "SessionDO" },
          { "name": "SANDBOX", "class_name": "Sandbox" },
          { "name": "RUNTIME_ROOM", "class_name": "RuntimeRoom", "script_name": "oma-managed-agents-staging" }
        ]
      },
      "kv_namespaces": [
        { "binding": "CONFIG_KV", "id": "f91ddab8abe64941bd3ef398b0c187a7" }
      ],
      "d1_databases": [
        { "binding": "MAIN_DB",    "database_name": "oma-auth-staging",          "database_id": "aff5dbb7-36f9-46b7-b82f-4513e5603ac6" },
        { "binding": "ROUTER_DB",  "database_name": "oma-router-staging",        "database_id": "c238a338-9b6e-40c5-aaaa-48d4fe6dc63d" },
        { "binding": "AUTH_DB_00", "database_name": "oma-auth-staging",          "database_id": "aff5dbb7-36f9-46b7-b82f-4513e5603ac6" },
        { "binding": "AUTH_DB_01", "database_name": "oma-auth-shard-01-staging", "database_id": "fe6a34d1-cd8a-48a1-bff1-29032026d006" },
        { "binding": "AUTH_DB_02", "database_name": "oma-auth-shard-02-staging", "database_id": "8636a018-8ac6-48c2-ae95-2f70919c8aab" },
        { "binding": "AUTH_DB_03", "database_name": "oma-auth-shard-03-staging", "database_id": "8ce8f17d-7527-4a5a-b097-ce73251be55a" }
      ],
      "ai": { "binding": "AI" },
      "worker_loaders": [
        { "binding": "LOADER" }
      ],
      "vars": {
        "MEMORY_BUCKET_NAME": "oma-managed-agents-memory-staging",
        "WORKSPACE_BUCKET_NAME": "oma-managed-agents-workspace",
        "BACKUP_BUCKET_NAME": "oma-managed-agents-backups",
        "CLOUDFLARE_ACCOUNT_ID": "44af79e51582ca20c9003eb926540242"
      },
      "r2_buckets": [
        { "binding": "WORKSPACE_BUCKET", "bucket_name": "oma-managed-agents-workspace" },
        { "binding": "FILES_BUCKET", "bucket_name": "oma-managed-agents-files" },
        { "binding": "BACKUP_BUCKET", "bucket_name": "oma-managed-agents-backups" },
        { "binding": "MEMORY_BUCKET", "bucket_name": "oma-managed-agents-memory-staging" }
      ],
      "browser": { "binding": "BROWSER" },
      "limits": { "cpu_ms": 300000 },
      "observability": { "enabled": true },
      "analytics_engine_datasets": [
        { "binding": "ANALYTICS", "dataset": "oma_events_staging" }
      ]
    }
  }
}
