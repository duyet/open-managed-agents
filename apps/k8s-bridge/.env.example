# Required: Bearer token for API authentication
K8S_BRIDGE_TOKEN=change-me

# Server port (default 8100)
PORT=8100

# Kubernetes namespace for sandbox pods (default "default")
OMA_K8S_NAMESPACE=default

# Container image for sandbox pods (default "node:22-slim")
SANDBOX_IMAGE=node:22-slim

# Optional Kubernetes pod configuration
OMA_K8S_RUNTIME_CLASS=
OMA_K8S_SERVICE_ACCOUNT=
OMA_K8S_CPU=
OMA_K8S_MEMORY=
OMA_K8S_READY_TIMEOUT_MS=120000

# Slack notifications
SLACK_WEBHOOK_URL=
SLACK_NOTIFY_ON=box_created,box_destroyed,box_error,health_degraded

# Token scopes (comma-separated, "admin" = all scopes)
TOKEN_SCOPES=admin
