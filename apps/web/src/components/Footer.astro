---
// Shared site footer — a multi-column sitemap grouping every page by
// intent (Product / Features / Resources / Community). Rendered once in
// Base.astro so every page carries the same navigation. Reuses the site's
// existing link + surface tokens; no new styles.
import Logo from "./Logo.astro";

const columns: { heading: string; links: { label: string; href: string; external?: boolean }[] }[] = [
  {
    heading: "Product",
    links: [
      { label: "Overview", href: "/" },
      { label: "How it works", href: "/how-it-works/" },
      { label: "Features", href: "/features/" },
      { label: "Use cases", href: "/use-cases/" },
      { label: "Infrastructure", href: "/infrastructure/" },
    ],
  },
  {
    heading: "Features",
    links: [
      { label: "Agent Sandbox", href: "/features/agent-sandbox/" },
      { label: "Local Machine", href: "/features/local-machine/" },
      { label: "Coding Agents", href: "/features/coding-agents/" },
      { label: "Open Tag", href: "/open-tag/" },
      { label: "Open Source Tag", href: "/claude-tag-open-source/" },
      { label: "Self-hosted Tag", href: "/self-hosted-claude-tag/" },
    ],
  },
  {
    heading: "Resources",
    links: [
      { label: "Docs", href: "https://docs.oma.duyet.net", external: true },
      { label: "Blog", href: "/blog/" },
      { label: "Stats", href: "/stats/" },
      { label: "Brand", href: "/brand/" },
      { label: "RSS", href: "/blog/rss.xml" },
    ],
  },
  {
    heading: "Community",
    links: [
      { label: "GitHub", href: "https://github.com/duyet/oma", external: true },
      { label: "Dashboard", href: "https://app.oma.duyet.net/", external: true },
      { label: "Try hosted", href: "https://app.oma.duyet.net/login", external: true },
    ],
  },
];
---

<footer class="border-t border-[var(--color-border)] mt-20">
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-8">
      {
        columns.map((col) => (
          <nav aria-label={col.heading}>
            <h2 class="font-mono text-[11px] uppercase tracking-widest text-[var(--color-fg-subtle)] mb-3">
              {col.heading}
            </h2>
            <ul class="flex flex-col gap-1 text-sm text-[var(--color-fg-muted)]">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                    class="inline-block py-1 hover:text-[var(--color-fg)] transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <div class="mt-10 pt-6 border-t border-[var(--color-border)] flex items-center gap-2 text-sm text-[var(--color-fg-muted)]">
      <Logo size={18} class="text-[var(--color-brand)]" />
      <span>© {new Date().getFullYear()} Open Managed Agents. Apache 2.0 licensed.</span>
    </div>
  </div>
</footer>
