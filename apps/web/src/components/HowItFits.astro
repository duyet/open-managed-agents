---
// Static mirror of the Console's "How it fits together" panel
// (apps/console/src/components/StackedAssembly.tsx) for the landing hero.
// Same visual grammar — numbered step columns, dashed type-cards with
// instance badges, the composition formula, flow pointers — but purely
// decorative: no links, no live data, example instances hard-coded.
// Keep the two in sync when the console layout changes.

interface FitCard {
  title: string;
  badges?: string[];
  note?: string;
  hero?: boolean;
  dashed?: boolean;
  /** Shown in the click-to-open dialog: what this piece IS in the system. */
  desc: string;
  /** Render an overlapping avatar-group of provider marks (+N overflow)
   *  under the note — the Sandbox card shows logos, not a name list. */
  logoGroup?: boolean;
}

// Monochrome provider coins for the Sandbox card's avatar group. Marks
// mirror the fleet band in index.astro (Simple Icons CC0 / lucide ISC).
const sandboxMarks: { label: string; mode: "fill" | "stroke"; inner: string }[] = [
  {
    label: "Cloudflare",
    mode: "fill",
    inner: `<path d="M16.5088 16.8447c.1475-.5068.0908-.9707-.1553-1.3154-.2246-.3164-.6045-.499-1.0615-.5205l-8.6592-.1123a.1559.1559 0 0 1-.1333-.0713c-.0283-.042-.0351-.0986-.021-.1553.0278-.084.1123-.1484.2036-.1562l8.7359-.1123c1.0351-.0489 2.1601-.8868 2.5537-1.9136l.499-1.3013c.0215-.0561.0293-.1128.0147-.168-.5625-2.5463-2.835-4.4453-5.5499-4.4453-2.5039 0-4.6284 1.6177-5.3876 3.8614-.4927-.3658-1.1187-.5625-1.794-.499-1.2026.119-2.1665 1.083-2.2861 2.2856-.0283.31-.0069.6128.0635.894C1.5683 13.171 0 14.7754 0 16.752c0 .1748.0142.3515.0352.5273.0141.083.0844.1475.1689.1475h15.9814c.0909 0 .1758-.0645.2032-.1553l.12-.4268zm2.7568-5.5634c-.0771 0-.1611 0-.2383.0112-.0566 0-.1054.0415-.127.0976l-.3378 1.1744c-.1475.5068-.0918.9707.1543 1.3164.2256.3164.6055.498 1.0625.5195l1.8437.1133c.0557 0 .1055.0263.1329.0703.0283.043.0351.1074.0214.1562-.0283.084-.1132.1485-.204.1553l-1.921.1123c-1.041.0488-2.1582.8867-2.5527 1.914l-.1406.3585c-.0283.0713.0215.1416.0986.1416h6.5977c.0771 0 .1474-.0489.169-.126.1122-.4082.1757-.837.1757-1.2803 0-2.6025-2.125-4.727-4.7344-4.727"/>`,
  },
  {
    label: "Kubernetes",
    mode: "stroke",
    inner: `<path d="M12 2 3 7v10l9 5 9-5V7z"/><circle cx="12" cy="12" r="3.5"/>`,
  },
  {
    label: "OpenShell",
    mode: "fill",
    inner: `<path d="M8.948 8.798v-1.43a6.7 6.7 0 0 1 .424-.018c3.922-.124 6.493 3.374 6.493 3.374s-2.774 3.851-5.75 3.851c-.398 0-.787-.062-1.158-.185v-4.346c1.528.185 1.837.857 2.747 2.385l2.04-1.714s-1.492-1.952-4-1.952a6.016 6.016 0 0 0-.796.035m0-4.735v2.138l.424-.027c5.45-.185 9.01 4.47 9.01 4.47s-4.08 4.964-8.33 4.964c-.37 0-.733-.035-1.095-.097v1.325c.3.035.61.062.91.062 3.957 0 6.82-2.023 9.593-4.408.459.371 2.34 1.263 2.73 1.652-2.633 2.208-8.772 3.984-12.253 3.984-.335 0-.653-.018-.971-.053v1.864H24V4.063zm0 10.326v1.131c-3.657-.654-4.673-4.46-4.673-4.46s1.758-1.944 4.673-2.262v1.237H8.94c-1.528-.186-2.73 1.245-2.73 1.245s.68 2.412 2.739 3.11M2.456 10.9s2.164-3.197 6.5-3.533V6.201C4.153 6.59 0 10.653 0 10.653s2.35 6.802 8.948 7.42v-1.237c-4.84-.6-6.492-5.936-6.492-5.936z"/>`,
  },
  {
    label: "E2B",
    mode: "stroke",
    inner: `<path d="M9 4H5v16h4M15 4h4v16h-4"/>`,
  },
  {
    label: "Daytona",
    mode: "stroke",
    inner: `<path d="M17.5 19a4.5 4.5 0 1 0-.42-8.98A6 6 0 1 0 6 19h11.5"/>`,
  },
  {
    label: "Docker",
    mode: "stroke",
    inner: `<rect x="3" y="9" width="4" height="4"/><rect x="8" y="9" width="4" height="4"/><rect x="8" y="4" width="4" height="4"/><path d="M2 15h20c-.5 4-4 6-9 6s-10-2-11-6z"/>`,
  },
  {
    label: "Subprocess",
    mode: "stroke",
    inner: `<path d="m4 17 6-6-6-6"/><path d="M12 19h8"/>`,
  },
];

type FitRow = FitCard | FitCard[];

interface FitStep {
  number: string;
  name: string;
  optional?: boolean;
  chain?: boolean;
  /** Labels the chain's ↓ arrows (index i annotates the arrow before row
   *  i+1) — RUN's two arrows mean different things. */
  chainLabels?: string[];
  wide?: boolean;
  cards: FitRow[];
}

const steps: FitStep[] = [
  {
    number: "1",
    name: "Configure",
    cards: [
      {
        title: "API key",
        badges: ["cli"],
        desc: "Authenticates the CLI and your programs against your OMA instance. Every REST call, SDK call, and `oma` CLI command presents one — scoped to your tenant.",
      },
      {
        title: "Model card",
        badges: ["claude-sonnet-4-6"],
        desc: "The AI brain, made pluggable. A model card binds a model id to a provider and credentials — Anthropic, any OpenAI-compatible gateway, or your own endpoint. Agents reference it by handle, so swapping providers never touches agent config.",
      },
    ],
  },
  {
    number: "2",
    name: "Compose",
    wide: true,
    cards: [
      {
        title: "Agent",
        badges: ["support-bot"],
        hero: true,
        desc: "The thing you're building: agent = model + skills + mcp. A versioned configuration — system prompt, tools, skills, MCP servers, callable sub-agents. Stateless by itself; every conversation with it runs as a session.",
      },
      {
        title: "Skills",
        badges: ["xlsx", "pdf", "pptx"],
        desc: "Reusable know-how: prompt fragments and files mounted into the sandbox and injected into the system prompt. Write a skill once, attach it to any number of agents.",
      },
      [
        {
          title: "Memory",
          note: "Notes it keeps",
          dashed: true,
          desc: "Persistent memory stores, mounted into the sandbox at /mnt/memory/<name>. The agent reads and writes them with ordinary file tools, so knowledge survives across sessions — versioned, auditable, and rollback-able.",
        },
        {
          title: "Files",
          note: "Data to mount",
          dashed: true,
          desc: "Files you upload once and mount into any session's sandbox at a path you choose — datasets, configs, reference documents. Created once, attached to sessions at runtime.",
        },
      ],
    ],
  },
  {
    number: "3",
    name: "Run",
    chain: true,
    chainLabels: ["+ agent =", "runs inside"],
    cards: [
      [
        {
          title: "Environment",
          badges: ["cloudflare"],
          desc: "Defines the execution sandbox: which provider runs it (Cloudflare, Kubernetes, OpenShell, E2B, …), what packages are preinstalled, and what networking is allowed. Reusable across agents and sessions.",
        },
        {
          title: "Keys (Vault)",
          badges: ["prod-secrets"],
          desc: "Secrets the agent calls out with — API tokens, OAuth credentials. Injected by an outbound proxy at the network layer, so raw credentials never enter the sandbox the agent controls.",
        },
      ],
      {
        title: "Session",
        note: "One conversation or task — streamed, resumable event log.",
        desc: "One conversation or task: session = agent + env + vaults. An append-only, durably-stored event log — streamed over SSE, resumable after crashes, pausable to stop paying for idle compute.",
      },
      {
        title: "Sandbox",
        note: "Set by your environment.",
        logoGroup: true,
        desc: "The isolated container or micro-VM where the agent's tools actually execute — bash, files, browsers. Provisioned per session by whichever provider the environment selects: Cloudflare, Kubernetes, NVIDIA OpenShell, E2B, Daytona, Docker, and more.",
      },
    ],
  },
  {
    number: "4",
    name: "Reach",
    optional: true,
    cards: [
      {
        title: "Channels",
        note: "Telegram, Slack, GitHub",
        dashed: true,
        desc: "Wire the agent into where work already happens: Telegram chats, Slack workspaces, GitHub issues and PRs. Each message in becomes a session turn; replies flow back to the channel.",
      },
      {
        title: "Publications",
        note: "Public chat page or widget",
        dashed: true,
        desc: "Publish the agent as a consumer-facing bot: a hosted chat page, an embeddable widget, guest access, and optional per-message billing — no OMA account needed for end users.",
      },
    ],
  },
];

const formula = [
  { lhs: "agent", rhs: "model + skills + mcp" },
  { lhs: "session", rhs: "agent + env + vaults" },
];

const rows = (step: FitStep): FitCard[][] =>
  step.cards.map((r) => (Array.isArray(r) ? r : [r]));
---

<div class="fits" aria-label="How it fits together">
  <div class="fits-formula" aria-hidden="true">
    {formula.map((f) => (
      <div class="fits-formula-row">
        <span class="fits-formula-lhs">{f.lhs}</span>
        <span class="fits-formula-eq">=</span>
        <span class="fits-formula-rhs">{f.rhs}</span>
      </div>
    ))}
  </div>

  <div class="fits-flow">
    {steps.map((step, i) => (
      <>
        {i > 0 && (
          <div class="fits-pointer" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </div>
        )}
        <div class:list={["fits-step", step.wide && "fits-step-wide"]}>
          <div class="fits-step-head">
            <span>{step.number} · {step.name}</span>
            {step.optional && <span class="fits-optional">optional</span>}
          </div>
          <div class:list={["fits-cards", step.chain && "fits-cards-chain"]}>
            {rows(step).map((row, ri) => (
              <>
                {step.chain && ri > 0 && (
                  <div class="fits-down" aria-hidden="true">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M6 13l6 6 6-6" /></svg>
                    {step.chainLabels?.[ri - 1] && (
                      <span class="fits-down-label">{step.chainLabels[ri - 1]}</span>
                    )}
                  </div>
                )}
                <div class="fits-row">
                  {row.map((card) => (
                    <button
                      type="button"
                      class:list={["fits-card", card.hero && "fits-card-hero", card.dashed && "fits-card-dashed"]}
                      data-fits-title={card.title}
                      data-fits-desc={card.desc}
                      aria-haspopup="dialog"
                      aria-label={`What is ${card.title}?`}
                    >
                      <div class="fits-card-top">
                        <span class="fits-card-title">{card.title}</span>
                        <span class:list={["fits-dot", card.dashed && "fits-dot-empty"]} />
                      </div>
                      {card.badges && (
                        <div class="fits-badges">
                          {card.badges.map((b) => <span class="fits-badge">{b}</span>)}
                        </div>
                      )}
                      {card.note && <div class="fits-note">{card.note}</div>}
                      {card.logoGroup && (
                        <div class="fits-coins" aria-label="Sandbox providers">
                          {sandboxMarks.slice(0, 5).map((m) => (
                            <span class="fits-coin" title={m.label}>
                              <svg
                                viewBox="0 0 24 24"
                                {...(m.mode === "fill"
                                  ? { fill: "currentColor" }
                                  : { fill: "none", stroke: "currentColor", "stroke-width": "2", "stroke-linecap": "round", "stroke-linejoin": "round" })}
                                aria-hidden="true"
                                set:html={m.inner}
                              />
                            </span>
                          ))}
                          {sandboxMarks.length > 5 && (
                            <span class="fits-coin fits-coin-count">+{sandboxMarks.length - 5}</span>
                          )}
                        </div>
                      )}
                    </button>
                  ))}
                </div>
              </>
            ))}
          </div>
        </div>
      </>
    ))}
  </div>

  <dialog class="fits-dialog" aria-labelledby="fits-dialog-title">
    <div class="fits-dialog-head">
      <h3 id="fits-dialog-title"></h3>
      <button type="button" class="fits-dialog-close" aria-label="Close">✕</button>
    </div>
    <p class="fits-dialog-body"></p>
  </dialog>
</div>

<script>
  // Click a card → open the shared <dialog> with that component's system
  // description. Native dialog: ESC closes for free; a backdrop click and
  // the ✕ button close it too.
  for (const root of document.querySelectorAll<HTMLElement>(".fits")) {
    const dialog = root.querySelector<HTMLDialogElement>(".fits-dialog");
    if (!dialog) continue;
    const title = dialog.querySelector<HTMLElement>("#fits-dialog-title");
    const body = dialog.querySelector<HTMLElement>(".fits-dialog-body");
    for (const card of root.querySelectorAll<HTMLElement>("[data-fits-title]")) {
      card.addEventListener("click", () => {
        if (title) title.textContent = card.dataset.fitsTitle ?? "";
        if (body) body.textContent = card.dataset.fitsDesc ?? "";
        dialog.showModal();
      });
    }
    dialog.querySelector(".fits-dialog-close")?.addEventListener("click", () => dialog.close());
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });
  }
</script>

<style>
  .fits {
    text-align: left;
  }
  .fits-formula {
    display: inline-flex;
    flex-direction: column;
    gap: 0.15rem;
    margin-bottom: 1rem;
    padding: 0.55rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: color-mix(in srgb, var(--color-bg-surface) 40%, transparent);
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 11.5px;
    line-height: 1.5;
  }
  .fits-formula-row { display: flex; gap: 0.4rem; align-items: baseline; }
  .fits-formula-lhs { width: 3.6rem; color: var(--color-brand); font-weight: 600; }
  .fits-formula-eq { color: var(--color-fg-subtle); }
  .fits-formula-rhs { color: var(--color-fg-muted); }

  .fits-flow {
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }
  @media (min-width: 1024px) {
    .fits-flow { flex-direction: row; }
  }
  .fits-pointer {
    display: flex;
    align-items: center;
    justify-content: center;
    align-self: center;
    padding: 0.2rem 0.15rem;
    color: var(--color-fg-subtle);
  }
  .fits-step {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    padding: 0.7rem;
    border: 1px dashed color-mix(in srgb, var(--color-border) 70%, transparent);
    border-radius: 8px;
  }
  @media (min-width: 1024px) {
    .fits-step-wide { flex: 1.35; }
  }
  .fits-step-head {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.55rem;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 9.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-fg-subtle);
  }
  .fits-optional {
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0 0.4rem;
    font-size: 8.5px;
    letter-spacing: 0.08em;
  }
  .fits-cards {
    display: flex;
    flex: 1;
    flex-direction: column;
    justify-content: center;
    gap: 0.45rem;
  }
  .fits-cards-chain { gap: 0; }
  .fits-down {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    padding: 0.15rem 0;
    color: var(--color-fg-subtle);
  }
  .fits-down-label {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 10px;
  }
  .fits-row { display: flex; flex-wrap: wrap; align-items: stretch; gap: 0.45rem; }
  .fits-row > .fits-card { flex: 1; min-width: 7.5rem; }
  .fits-card {
    display: block;
    width: 100%;
    text-align: left;
    font: inherit;
    color: inherit;
    cursor: pointer;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-bg);
    padding: 0.5rem 0.6rem;
    transition: border-color 0.15s ease, background-color 0.15s ease;
  }
  .fits-card:hover { border-color: var(--color-border-strong, var(--color-border)); }
  .fits-card:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--color-brand) 50%, transparent);
    outline-offset: 1px;
  }
  .fits-dialog {
    /* The global reset zeroes margins, which wipes out the UA's
       `margin: auto` dialog centering — restore it explicitly. */
    position: fixed;
    inset: 0;
    margin: auto;
    height: fit-content;
    max-height: calc(100dvh - 3rem);
    overflow-y: auto;
    max-width: 26rem;
    width: calc(100vw - 2.5rem);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: var(--color-bg);
    color: var(--color-fg);
    padding: 1.1rem 1.25rem 1.25rem;
  }
  .fits-dialog::backdrop {
    background: color-mix(in srgb, var(--color-bg) 60%, transparent);
    backdrop-filter: blur(2px);
  }
  .fits-dialog-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .fits-dialog-head h3 {
    font-size: 1rem;
    font-weight: 650;
    letter-spacing: -0.01em;
  }
  .fits-dialog-close {
    border: 0;
    background: transparent;
    color: var(--color-fg-subtle);
    font-size: 0.85rem;
    cursor: pointer;
    padding: 0.15rem 0.3rem;
  }
  .fits-dialog-close:hover { color: var(--color-fg); }
  .fits-dialog-body {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-fg-muted);
  }
  .fits-card-hero {
    border-color: color-mix(in srgb, var(--color-brand) 50%, transparent);
    background: color-mix(in srgb, var(--color-brand) 5%, transparent);
  }
  .fits-card-dashed {
    border-style: dashed;
    background: transparent;
    opacity: 0.75;
  }
  .fits-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.4rem;
  }
  .fits-card-title {
    font-size: 12px;
    font-weight: 550;
    color: var(--color-fg);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .fits-card-hero .fits-card-title { font-size: 13.5px; font-weight: 650; }
  .fits-dot {
    flex-shrink: 0;
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--color-success, #22c55e);
  }
  .fits-dot-empty { background: transparent; border: 1px solid var(--color-border); }
  .fits-badges { margin-top: 0.35rem; display: flex; flex-wrap: wrap; gap: 0.25rem; }
  .fits-badge {
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: color-mix(in srgb, var(--color-bg-surface) 60%, transparent);
    padding: 0.05rem 0.35rem;
    font-size: 10px;
    color: var(--color-fg-muted);
    white-space: nowrap;
  }
  .fits-note {
    margin-top: 0.3rem;
    font-size: 10.5px;
    line-height: 1.45;
    color: var(--color-fg-muted);
  }
  .fits-coins { margin-top: 0.45rem; display: flex; align-items: center; }
  .fits-coin {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.35rem;
    height: 1.35rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-surface);
    box-shadow: 0 0 0 2px var(--color-bg);
    color: var(--color-fg-muted);
  }
  .fits-coin + .fits-coin { margin-left: -0.35rem; }
  .fits-coin svg { width: 0.8rem; height: 0.8rem; }
  .fits-coin-count { font-size: 9px; font-weight: 600; }
</style>
