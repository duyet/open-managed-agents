---
/**
 * Pixel-art agent mascot (v3 — head/body silhouette, glowing core). A cheerful
 * pixel robot: dark outline, warm terracotta shell, a light visor with dark
 * blinking eyes, a pulsing antenna tip and chest core, and stubby arms. The
 * mascot stays deliberately *warm* — a playful secondary mark, kept distinct
 * from the iris (indigo) brand chrome so the page reads as "serious tool,
 * friendly guide". Uses the site's CSS custom properties so it follows
 * light/dark, and shape-rendering: crispEdges (set in the .pixel-art global
 * rule) keeps blocks hard-edged at any scale. Eyes blink via .pa-eye
 * keyframes (global.css); the antenna tip + core pulse via the local
 * .pa-glow keyframes below.
 */
const PALETTE: Record<string, string> = {
  K: "var(--color-fg)",
  O: "var(--color-accent)",
  B: "var(--color-bg-surface)",
  E: "var(--color-fg)",
  G: "var(--color-accent)",
};

// 20×20 grid. `.` = transparent. E = eye (blinks), G = glow (pulses).
const MAP = [
  "....................",
  ".........GG.........",
  ".........KK.........",
  ".....KKKKKKKKKK.....",
  ".....KOOOOOOOOK.....",
  ".....KOBBBBBBOK.....",
  ".....KOBEBBEBOK.....",
  ".....KOBBBBBBOK.....",
  ".....KOOOKKOOOK.....",
  ".....KKKKKKKKKK.....",
  "........KOOK........",
  "....KKKKKKKKKKKK....",
  "...KOOOOOOOOOOOOK...",
  ".KKKOOOGGGGOOOOKKK..",
  ".KOKOOOGGGGOOOOKOK..",
  ".KKKOOOOOOOOOOOKKK..",
  "....KOOOOOOOOOOK....",
  "....KKKKKKKKKKKK....",
  "......KK....KK......",
  ".....KK......KK.....",
];

const PX = 10;
const cols = MAP[0].length;
const rows = MAP.length;

const rects = [];
for (let y = 0; y < rows; y++) {
  for (let x = 0; x < MAP[y].length; x++) {
    const ch = MAP[y][x];
    if (ch === "." || ch === " ") continue;
    rects.push({
      x: x * PX,
      y: y * PX,
      fill: PALETTE[ch],
      eye: ch === "E",
      glow: ch === "G",
    });
  }
}

interface Props {
  /** Pixel size of the rendered SVG (CSS px). Scales crisply. */
  size?: number;
  class?: string;
}

const { size = 200, class: className = "" } = Astro.props;
---

<svg
  class:list={["pixel-art", className]}
  width={size}
  height={size}
  viewBox={`0 0 ${cols * PX} ${rows * PX}`}
  role="img"
  aria-label="oma pixel-art agent mascot"
  shape-rendering="crispEdges"
>
  {rects.map((r) => (
    <rect
      x={r.x}
      y={r.y}
      width={PX}
      height={PX}
      fill={r.fill}
      class={r.eye ? "pa-eye" : r.glow ? "pa-glow" : undefined}
    />
  ))}
</svg>

<style>
  .pa-glow {
    animation: pa-glow-pulse 2.4s ease-in-out infinite;
  }
  @keyframes pa-glow-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.45;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .pa-glow {
      animation: none;
    }
  }
</style>
