---
// "Built for Real Workflows" section — interactive use-case tabs + CTA.
// The tab rail + animated visual live in UseCasesInteractive.tsx (React
// island); this wrapper owns the section chrome and the CTA.
import UseCasesInteractive from "./UseCasesInteractive.tsx";
import Icon from "./Icon.astro";
---

<section class="max-w-5xl mx-auto px-4 py-16 md:py-20" data-reveal id="use-cases">
  <p class="flex items-center justify-center gap-2 font-mono text-xs uppercase tracking-widest text-[var(--color-fg-subtle)] mb-3">
    <Icon name="workflow" size={14} class="text-[var(--color-brand)]" /> Workflows
  </p>
  <h2 class="font-display text-3xl md:text-4xl font-bold mb-4 text-center tracking-tight">
    Built for Real Workflows
  </h2>
  <p class="text-center text-[var(--color-fg-muted)] max-w-2xl mx-auto mb-12 leading-relaxed">
    Ship code, run production, answer customers, work a Slack thread. Pick a
    workflow to watch it run.
  </p>

  <UseCasesInteractive client:visible />

  <!-- Companion grid: use cases where a crisp card reads clearer than an
       animated trace. Same shadcn-clean card language as the rest of the site. -->
  <div class="grid sm:grid-cols-2 gap-5 mt-6">
    <article
      data-lift
      class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] p-6 hover:border-[var(--color-border-strong)]"
    >
      <div class="w-10 h-10 rounded-lg bg-[var(--color-brand-subtle)] flex items-center justify-center mb-3 shrink-0 text-[var(--color-brand)]">
        <Icon name="globe" size={20} />
      </div>
      <h3 class="font-display text-lg font-semibold mb-2 tracking-tight">Publish a consumer bot</h3>
      <p class="text-sm text-[var(--color-fg-muted)] leading-relaxed">
        Ship an agent as a public chatbot: a hosted
        <code class="font-mono text-xs">/p/&lt;slug&gt;</code> page, a one-line
        <code class="font-mono text-xs">widget.js</code> embed, guest or magic-link
        sign-in, and optional Stripe billing.
      </p>
    </article>

    <article
      data-lift
      class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] p-6 hover:border-[var(--color-border-strong)]"
    >
      <div class="w-10 h-10 rounded-lg bg-[var(--color-brand-subtle)] flex items-center justify-center mb-3 shrink-0 text-[var(--color-brand)]">
        <Icon name="calendar" size={20} />
      </div>
      <h3 class="font-display text-lg font-semibold mb-2 tracking-tight">Scheduled &amp; proactive runs</h3>
      <p class="text-sm text-[var(--color-fg-muted)] leading-relaxed">
        Fire sessions on a cron, no human in the loop — weekly digests, polling jobs,
        nightly maintenance. Five-field cron, IANA timezones, including Cloudflare.
      </p>
    </article>
  </div>

  <div class="mt-12 text-center">
    <a
      href="https://docs.oma.duyet.net/quickstart"
      class="inline-flex items-center gap-2 px-6 py-3 rounded-md bg-[var(--color-brand)] text-[var(--color-brand-fg)] font-medium font-display no-underline hover:no-underline hover:bg-[var(--color-brand-hover)] transition-colors"
    >
      Get Started <Icon name="arrowRight" size={16} />
    </a>
  </div>
</section>
