---
import "../styles/global.css";
import Logo from "../components/Logo.astro";
import Icon from "../components/Icon.astro";
import { organizationSchema, websiteSchema } from "../lib/seo";

export interface Props {
  title: string;
  description?: string;
  /** Canonical path under https://oma.duyet.net — leading slash. */
  canonical?: string;
  /** og:type. Default "website"; "article" for blog posts. */
  ogType?: "website" | "article";
  publishedAt?: Date;
  updatedAt?: Date;
  /** Absolute URL to a per-page OG image. Falls back to /og-default.png. */
  ogImage?: string;
  /** Extra JSON-LD blocks to inject (e.g. BlogPosting, BreadcrumbList). */
  schemas?: Array<Record<string, unknown>>;
  /** Comma-separated keywords for the page (used in meta keywords + JSON-LD). */
  keywords?: string;
}

const {
  title,
  description,
  canonical,
  ogType = "website",
  publishedAt,
  updatedAt,
  ogImage,
  schemas = [],
  keywords,
} = Astro.props;

const SITE = "https://oma.duyet.net";
// Append " — Open Managed Agents" only when the title doesn't already
// contain the full brand. We deliberately don't match on "openma"
// alone, so a post like "Hello, openma" still gets the suffix for
// SERP branding.
const fullTitle = /open managed agents/i.test(title)
  ? title
  : `${title} — Open Managed Agents`;
const desc = description ?? "Open-source alternative to Claude Managed Agents. Run Claude agents yourself on Cloudflare Workers or Docker. MCP + Claude Code skills built in. Apache 2.0.";
const url = canonical ? `${SITE}${canonical}` : Astro.url.toString();
const finalOgImage = ogImage ?? `${SITE}/og-default.png`;

const allSchemas = [organizationSchema(), websiteSchema(), ...schemas];
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={url} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />

    <!-- Color scheme — let browsers pick chrome that matches our theme. -->
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#4f46e5" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#818cf8" media="(prefers-color-scheme: dark)" />

    <!-- Favicons + manifest. SVG primary; PNG fallbacks for Safari /
         Android home screen. The PNG set is generated from
         public/og-default.svg + the wordmark — see public/README.md.
         /favicon.ico is the path Google's favicon crawler checks
         first, so we ship it explicitly to avoid SERP fallback to
         the generic placeholder. -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Theme: system preference with manual override. Also flips an
         `html.js` flag so JS-gated CSS rules (e.g. the scroll-reveal
         hidden state) only apply when JS is actually running — keeps
         JS-disabled visitors from staring at invisible sections. -->
    <script is:inline>
      document.documentElement.classList.add("js");
      const t = localStorage.getItem("theme");
      if (t === "dark" || (!t && matchMedia("(prefers-color-scheme: dark)").matches)) {
        document.documentElement.classList.add("dark");
      }
    </script>

    <!-- Brand fonts are self-hosted via @fontsource-variable/geist +
         @fontsource-variable/geist-mono (imported in global.css) — Geist,
         the same family Cursor.com ships. No external font request, so we
         drop the Google Fonts <link> that the old Poppins/Lora setup used. -->

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={url} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Open Managed Agents" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={finalOgImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={fullTitle} />
    {publishedAt && (
      <meta property="article:published_time" content={publishedAt.toISOString()} />
    )}
    {updatedAt && (
      <meta property="article:modified_time" content={updatedAt.toISOString()} />
    )}

    <!-- Twitter/X cards. We intentionally omit twitter:site until a
         verified project handle exists, but explicit card metadata avoids
         small-card fallbacks in link unfurlers. -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={finalOgImage} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Open Managed Agents — Blog" href="/blog/rss.xml" />

    <!-- JSON-LD structured data — Organization + WebSite on every page,
         plus per-page schemas (BlogPosting, BreadcrumbList) injected by callers. -->
    {allSchemas.map((schema) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class="bg-bg text-fg">
    <!-- Skip-to-content for keyboard users. sr-only by default, becomes
         visible on :focus-visible (next focusable element after document
         start), so the very first Tab press exposes it. -->
    <a
      href="#main"
      class="sr-only focus-visible:not-sr-only focus-visible:fixed focus-visible:top-3 focus-visible:left-3 focus-visible:z-50 focus-visible:px-3 focus-visible:py-2 focus-visible:rounded-md focus-visible:bg-[var(--color-fg)] focus-visible:text-[var(--color-bg)] focus-visible:font-medium focus-visible:no-underline"
    >
      Skip to content
    </a>

    <header
      class="sticky top-0 z-40 border-b border-transparent"
      data-site-header
    >
      <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between gap-3">
        <a
          href="/"
          class="flex items-center gap-2 py-1.5 group"
          aria-label="Open Managed Agents — home"
        >
          <Logo size={26} class="text-[var(--color-brand)]" />
          <span class="font-mono font-bold tracking-tight text-[var(--color-fg)]">oma</span>
        </a>

        <!-- Desktop nav -->
        <nav class="hidden md:flex items-center gap-0.5 text-sm" aria-label="Primary">
          <a href="/open-tag/" class="px-3 py-2 rounded-md text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] hover:bg-[var(--color-bg-surface)] transition-colors">Open Tag</a>
          <a href="/blog/" class="px-3 py-2 rounded-md text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] hover:bg-[var(--color-bg-surface)] transition-colors">Blog</a>
          <a href="https://docs.oma.duyet.net" class="inline-flex items-center gap-1.5 px-3 py-2 rounded-md text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] hover:bg-[var(--color-bg-surface)] transition-colors">
            <Icon name="book" size={15} /> Docs
          </a>
          <a
            href="https://github.com/duyet/oma"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 px-3 py-2 rounded-md text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] hover:bg-[var(--color-bg-surface)] transition-colors"
            ><Icon name="github" size={15} /> GitHub</a
          >
          <button
            type="button"
            data-theme-toggle
            aria-label="Toggle color theme"
            aria-pressed="false"
            title="Toggle color theme"
            class="ml-1 inline-flex items-center justify-center w-10 h-10 rounded-md text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] hover:bg-[var(--color-bg-surface)] transition-colors"
          >
            <!-- Sun (visible in dark mode) -->
            <svg
              class="hidden dark:block w-4 h-4"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="4" />
              <path
                stroke-linecap="round"
                d="M12 3v1.5M12 19.5V21M3 12h1.5M19.5 12H21M5.6 5.6l1.1 1.1M17.3 17.3l1.1 1.1M5.6 18.4l1.1-1.1M17.3 6.7l1.1-1.1"
              />
            </svg>
            <!-- Moon (visible in light mode) -->
            <svg
              class="block dark:hidden w-4 h-4"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"
              />
            </svg>
          </button>
          <!-- Points at the console root, not /login: signed-in visitors land
               on the dashboard the label promises, and AppShell still bounces
               signed-out ones to /login. -->
          <a
            href="https://app.oma.duyet.net/"
            class="ml-2 px-3.5 py-2 rounded-md bg-[var(--color-brand)] text-[var(--color-brand-fg)] font-medium hover:bg-[var(--color-brand-hover)] transition-colors"
            >Dashboard →</a
          >
        </nav>

        <!-- Mobile: theme toggle + hamburger via <details>. JS-free; the
             <summary> handles toggle. Closes on backdrop click via the
             absolute panel design + click-outside detection in the
             inline script below. -->
        <div class="md:hidden flex items-center gap-1">
          <button
            type="button"
            data-theme-toggle
            aria-label="Toggle color theme"
            aria-pressed="false"
            class="inline-flex items-center justify-center w-11 h-11 rounded-md text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] hover:bg-[var(--color-bg-surface)] transition-colors"
          >
            <svg class="hidden dark:block w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="4" />
              <path stroke-linecap="round" d="M12 3v1.5M12 19.5V21M3 12h1.5M19.5 12H21M5.6 5.6l1.1 1.1M17.3 17.3l1.1 1.1M5.6 18.4l1.1-1.1M17.3 6.7l1.1-1.1" />
            </svg>
            <svg class="block dark:hidden w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
            </svg>
          </button>
          <details class="relative" data-mobile-menu>
            <summary
              class="list-none inline-flex items-center justify-center w-11 h-11 rounded-md text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] hover:bg-[var(--color-bg-surface)] transition-colors cursor-pointer"
              aria-label="Open menu"
            >
              <svg class="block w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16" />
              </svg>
            </summary>
            <nav
              class="absolute right-0 top-full mt-2 min-w-[180px] py-2 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-md shadow-lg flex flex-col text-sm z-40"
              aria-label="Mobile primary"
            >
              <a href="/open-tag/" class="block px-4 py-3 hover:bg-[var(--color-bg-surface)]">Open Tag</a>
              <a href="/blog/" class="block px-4 py-3 hover:bg-[var(--color-bg-surface)]">Blog</a>
              <a href="https://docs.oma.duyet.net" class="block px-4 py-3 hover:bg-[var(--color-bg-surface)]">Docs</a>
              <a
                href="https://github.com/duyet/oma"
                target="_blank"
                rel="noopener noreferrer"
                class="block px-4 py-3 hover:bg-[var(--color-bg-surface)]"
                >GitHub</a
              >
              <a
                href="https://app.oma.duyet.net/"
                class="block mx-2 mt-1 px-3 py-3 rounded-md text-center bg-[var(--color-brand)] text-[var(--color-brand-fg)] font-medium"
                >Dashboard →</a
              >
            </nav>
          </details>
        </div>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="border-t border-[var(--color-border)] mt-20">
      <div class="max-w-5xl mx-auto px-4 py-8 text-sm text-[var(--color-fg-muted)] flex flex-wrap gap-x-8 gap-y-2 justify-between">
        <div class="flex items-center gap-2">
          <Logo size={18} class="text-[var(--color-brand)]" />
          <span>© {new Date().getFullYear()} Open Managed Agents. Apache 2.0 licensed.</span>
        </div>
        <nav class="flex flex-wrap gap-x-3 gap-y-1" aria-label="Footer">
          <a href="/open-tag/" class="py-2 px-2 -mx-2 rounded hover:bg-[var(--color-bg-surface)]">Open Tag</a>
          <a href="/claude-tag-open-source/" class="py-2 px-2 rounded hover:bg-[var(--color-bg-surface)]">Open Source Tag</a>
          <a href="/self-hosted-claude-tag/" class="py-2 px-2 rounded hover:bg-[var(--color-bg-surface)]">Self-hosted Tag</a>
          <a href="/blog/" class="py-2 px-2 rounded hover:bg-[var(--color-bg-surface)]">Blog</a>
          <a href="/brand/" class="py-2 px-2 rounded hover:bg-[var(--color-bg-surface)]">Brand</a>
          <a href="https://docs.oma.duyet.net" class="py-2 px-2 rounded hover:bg-[var(--color-bg-surface)]">Docs</a>
          <a
            href="https://github.com/duyet/oma"
            target="_blank"
            rel="noopener noreferrer"
            class="py-2 px-2 rounded hover:bg-[var(--color-bg-surface)]"
            >GitHub</a
          >
          <a href="/blog/rss.xml" class="py-2 px-2 rounded hover:bg-[var(--color-bg-surface)]">RSS</a>
        </nav>
      </div>
    </footer>

    <!-- Theme toggle: writes localStorage and flips .dark on <html>.
         Pairs with the FOUC-free bootstrap script in <head>. Also closes
         the mobile menu when a link inside it is clicked or when clicking
         outside, since <details> doesn't auto-close on navigation.
         Also: toggles a data-scrolled flag on the sticky header so it
         picks up a shadow once the page leaves the top — cheap depth
         cue that costs nothing when reduced-motion is on. -->
    <script is:inline>
      // Sync theme-toggle aria-pressed with current theme on load + after each click.
      const syncThemePressed = () => {
        const isDark = document.documentElement.classList.contains('dark');
        for (const btn of document.querySelectorAll('[data-theme-toggle]')) {
          btn.setAttribute('aria-pressed', String(isDark));
        }
      };
      syncThemePressed();
      for (const btn of document.querySelectorAll('[data-theme-toggle]')) {
        btn.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          syncThemePressed();
        });
      }
      const menu = document.querySelector('[data-mobile-menu]');
      if (menu) {
        const summary = menu.querySelector('summary');
        // Flip aria-label when the disclosure opens/closes so SR users get
        // honest "Open menu" / "Close menu" feedback instead of stale text.
        const syncMenuLabel = () => {
          if (summary) summary.setAttribute('aria-label', menu.open ? 'Close menu' : 'Open menu');
        };
        menu.addEventListener('toggle', syncMenuLabel);
        syncMenuLabel();
        // Click outside closes
        document.addEventListener('click', (e) => {
          if (menu.open && !menu.contains(e.target)) menu.open = false;
        });
        // Click on a link inside the menu closes (in case of in-page nav)
        for (const a of menu.querySelectorAll('a')) {
          a.addEventListener('click', () => { menu.open = false; });
        }
      }
      // Sticky-header scroll state. Toggle once we're past 8px so the
      // shadow only appears when there's actually content behind it.
      const siteHeader = document.querySelector('[data-site-header]');
      if (siteHeader) {
        const syncScrolled = () => {
          if (window.scrollY > 8) siteHeader.setAttribute('data-scrolled', '');
          else siteHeader.removeAttribute('data-scrolled');
        };
        syncScrolled();
        window.addEventListener('scroll', syncScrolled, { passive: true });
      }

      // Scroll-reveal: sections with [data-reveal] fade in once they
      // enter the viewport. One-shot via `once: true`-style unobserve
      // so we don't pay observer cost forever. Reduced-motion users
      // skip this entirely (CSS guards the hidden state).
      const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
      const revealTargets = document.querySelectorAll('[data-reveal]');
      if (!reduceMotion && 'IntersectionObserver' in window && revealTargets.length) {
        const io = new IntersectionObserver((entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          }
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.05 });
        for (const el of revealTargets) io.observe(el);
      } else {
        // No-motion / no-IO fallback: show everything immediately.
        for (const el of revealTargets) el.classList.add('is-visible');
      }

      // Typewriter rotate: cycle the .tw-rot verb through data-rotate JSON on
      // any element. Char-by-char type + delete; skip entirely under
      // reduced-motion (the first verb stays put).
      if (!reduceMotion) {
        for (const el of document.querySelectorAll('[data-rotate]')) {
          const words = (() => { try { return JSON.parse(el.getAttribute('data-rotate') || '[]'); } catch { return []; } })();
          const out = el.querySelector('.tw-rot');
          if (!out || !words.length) continue;
          // If the first word is server-rendered (headline), start from the
          // full-word hold instead of retyping it on load.
          let w = 0, i = out.textContent === words[0] ? words[0].length : 0, deleting = false;
          const tick = () => {
            const word = words[w];
            out.textContent = word.slice(0, i);
            if (!deleting && i < word.length) i++;
            else if (!deleting && i === word.length) { deleting = true; setTimeout(tick, 1400); return; }
            else if (deleting && i > 0) i--;
            else { deleting = false; w = (w + 1) % words.length; }
            setTimeout(tick, deleting ? 45 : 95);
          };
          tick();
        }
      }
    </script>
  </body>
</html>
