---
import Base from "../../layouts/Base.astro";
import Icon from "../../components/Icon.astro";
import FeatureCard from "../../components/FeatureCard.astro";
import ManagedAgentsSection from "../../components/ManagedAgentsSection.astro";
import FeaturesSection from "../../components/FeaturesSection.astro";
import { breadcrumbSchema } from "../../lib/seo";

const schemas = [
  breadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Features", path: "/features/" },
  ]),
];
---

<Base
  title="Features | Open Managed Agents"
  description="Everything the platform gives you: sandboxed execution, built-in tools, secure credentials, multi-agent delegation, integrations — and drop-in compatibility with the Claude Managed Agents API."
  canonical="/features/"
  keywords="managed agents features, agent platform tools, self host claude agents, claude managed agents alternative, drop-in claude api"
  schemas={schemas}
>
  <!-- Page hero -->
  <section class="border-b border-[var(--color-border)]">
    <div class="max-w-5xl mx-auto px-4 py-14 md:py-16">
      <p class="flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-[var(--color-fg-subtle)] mb-3">
        <Icon name="grid" size={14} class="text-[var(--color-brand)]" /> Features
      </p>
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4 tracking-tight">
        Everything you need to run agent fleets
      </h1>
      <p class="text-lg text-[var(--color-fg-muted)] max-w-2xl leading-relaxed">
        The platform a closed vendor gives you — sessions, sandboxes, crash recovery,
        security — with every layer inspectable and yours to fork.
      </p>
    </div>
  </section>

  <ManagedAgentsSection />

  <FeaturesSection />

  <!-- Why -->
  <section class="border-y border-[var(--color-border)] bg-[var(--color-bg-surface)]" data-reveal id="why">
    <div class="max-w-5xl mx-auto px-4 py-16 md:py-20">
      <p class="flex items-center justify-center gap-2 font-mono text-xs uppercase tracking-widest text-[var(--color-fg-subtle)] mb-3">
        <Icon name="check" size={14} class="text-[var(--color-brand)]" /> Why
      </p>
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-4 text-center tracking-tight">Why Open Managed Agents</h2>
      <p class="text-center text-[var(--color-fg-muted)] max-w-2xl mx-auto mb-12 leading-relaxed">
        The platform a closed vendor gives you (sessions, sandboxes, crash
        recovery, security), with every layer inspectable and yours to fork.
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        <FeatureCard title="Drop-in compatible" accent>
          The HTTP API mirrors the Claude Managed Agents API — same
          <code class="font-mono text-xs">/v1/agents</code>,
          <code class="font-mono text-xs">/v1/sessions</code>, same event-stream
          shape. Migrate by swapping the base URL.
        </FeatureCard>
        <FeatureCard title="Self-host on Cloudflare">
          Workers + Durable Objects + Containers + R2. One <code class="font-mono text-xs">wrangler deploy</code>,
          no servers to patch. Or run the Node + Postgres flavor on your own
          VPS if you can't be on Cloudflare.
        </FeatureCard>
        <FeatureCard title="Apache 2.0">
          Permissive license. Fork it, ship it inside your product, run a
          private fleet — no per-seat fee, no usage tax. The hosted service at
          oma.duyet.net is one deployment of the same code.
        </FeatureCard>
      </div>
    </div>
  </section>

  <!-- API compatibility -->
  <section class="max-w-5xl mx-auto px-4 py-16 md:py-20" data-reveal id="api-compat">
    <p class="flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-[var(--color-fg-subtle)] mb-3">
      <Icon name="terminal" size={14} class="text-[var(--color-brand)]" /> API
    </p>
    <h2 class="font-display text-3xl md:text-4xl font-bold mb-4 tracking-tight">
      Drop-in compatible with the Claude Managed Agents API
    </h2>
    <p class="text-[var(--color-fg-muted)] leading-relaxed mb-8 max-w-2xl">
      Same resources, request and response shapes, and SSE event stream, one-to-one.
      Migrate by swapping the base URL; the harness layer is the part you get to
      rewrite. <a href="/blog/claude-managed-agents-vs-open-managed-agents/">Read the technical comparison</a>.
    </p>

    <!-- Base-URL swap diagram — the whole migration in one line. -->
    <div class="url-swap" role="region" aria-label="Point your existing client at your own base URL">
      <span class="url-swap-client">your client</span>
      <svg class="url-swap-arrow" width="26" height="10" viewBox="0 0 26 10" aria-hidden="true">
        <path d="M0 5h21M18 1l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span class="url-swap-stack">
        <span class="url-swap-old">api.anthropic.com</span>
        <span class="url-swap-new">oma.duyet.net <span class="url-swap-tag">hosted</span></span>
        <span class="url-swap-new">localhost:8787 <span class="url-swap-tag">self-host</span></span>
      </span>
    </div>
  </section>
</Base>
