---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import { softwareApplicationSchema } from "../lib/seo";
import FeatureCard from "../components/FeatureCard.astro";
import BlogPostCard from "../components/BlogPostCard.astro";


const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);

function formatDate(d: Date) {
  return d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
}

// SoftwareApplication is the homepage-only schema — anchors the
// "Open Managed Agents" entity in Google's knowledge graph and makes
// the page eligible for software-style rich snippets (price, license).
const schemas = [softwareApplicationSchema()];
---

<Base
  title="oma — Open Managed Agents: self-hosted agent platform for any LLM provider"
  description="oma (Open Managed Agents) is an open-source, self-hostable agent platform — durable sessions, sandboxed execution, MCP tools — that runs on Anthropic, OpenAI-compatible gateways, or your own model, on Cloudflare Workers or Docker."
  canonical="/"
  keywords="open managed agents, oma agent platform, self host ai agent, any llm provider agent platform, byok ai agent, claude agent sdk, mcp server host, ai agent cloudflare workers, self host claude code, claude code skills, claude managed agents alternative, claude tag alternative, open source claude tag"
  schemas={schemas}
>
  <!-- Hero -->
  <section class="border-b border-[var(--color-border)]">
    <div class="max-w-5xl mx-auto px-4 py-20 md:py-28 text-center">
      <p class="text-sm font-mono uppercase tracking-wider text-[var(--color-fg-subtle)] mb-4">
        Apache 2.0 · Cloudflare-native · Self-hostable · BYOK
      </p>
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight">
        oma — the self-hosted agent platform for any LLM provider
        <span class="block mt-4 text-xl md:text-2xl text-[var(--color-fg-muted)] font-medium">
          Run your own agents — on Cloudflare or with <code class="font-mono text-base md:text-xl">docker compose up</code>
        </span>
      </h1>
      <p class="mt-6 text-base md:text-lg text-[var(--color-fg-muted)] max-w-2xl mx-auto leading-relaxed">
        An open-source, self-hostable agent platform: durable sessions,
        sandboxed code execution across <strong>7 providers</strong> (Cloudflare
        Containers, local subprocess, Kubernetes, E2B, Daytona, LiteBox, BoxRun),
        vault-backed credentials, MCP server hosting, and Claude Code skills —
        served from Cloudflare Workers + Durable Objects, or a Docker container
        on your own box. BYOK for both LLM <em>and</em> sandbox — bring
        Anthropic, OpenAI, OpenRouter, <strong>and</strong> your preferred
        sandbox runtime.
      </p>
      <div class="mt-8 flex items-center justify-center gap-3 flex-wrap">
        <a
          href="https://github.com/duyet/oma"
          target="_blank" rel="noopener noreferrer"
          class="px-5 py-3 rounded-md bg-[var(--color-fg)] text-[var(--color-bg)] font-medium"
          >★ Star on GitHub</a
        >
        <a
          href="https://app.oma.duyet.net/login"
          class="px-5 py-3 rounded-md border border-[var(--color-border)] font-medium"
          >Try the hosted version</a
        >
      </div>
      <p class="mt-3 text-xs text-[var(--color-fg-subtle)]">
        Self-host: <code class="font-mono">docker compose up</code>. Hosted: Free trial, BYOK for LLM spend.
      </p>
    </div>
  </section>

  <!-- Why Open Managed Agents -->
  <section class="max-w-5xl mx-auto px-4 py-16" data-reveal>
    <h2 class="font-display text-3xl font-bold mb-3 text-center">Why Open Managed Agents</h2>
    <p class="text-center text-[var(--color-fg-muted)] max-w-2xl mx-auto mb-12">
      The same shape of platform you'd get from a closed vendor — sessions,
      sandboxes, tool dispatch, crash recovery, security controls — but every layer is
      inspectable, swappable, and yours to fork.
    </p>
    <div class="grid md:grid-cols-3 gap-8">
      <FeatureCard title="Drop-in compatible">
        The HTTP API mirrors the Claude Managed Agents API — same
        <code class="font-mono text-xs">/v1/agents</code>,
        <code class="font-mono text-xs">/v1/sessions</code>, same event-stream
        shape. Migrate by swapping the base URL.
      </FeatureCard>
      <FeatureCard title="Self-host on Cloudflare">
        Workers + Durable Objects + Containers + R2. One <code class="font-mono text-xs">wrangler deploy</code>,
        no servers to patch. Or run the Node + Postgres flavor on your own
        VPS if you can't be on Cloudflare.
      </FeatureCard>
      <FeatureCard title="Apache 2.0">
        Permissive license. Fork it, ship it inside your product, run a
        private fleet — no per-seat fee, no usage tax. The hosted service at
        oma.duyet.net is one deployment of the same code.
      </FeatureCard>
    </div>
  </section>

  <!-- How Open Managed Agents Works (Architecture & LifeCycle Diagrams) -->
  <section class="border-y border-[var(--color-border)] bg-[var(--color-bg-surface)]" data-reveal>
    <div class="max-w-5xl mx-auto px-4 py-16">
      <h2 class="font-display text-3xl font-bold mb-3 text-center">How Open Managed Agents works</h2>
      <p class="text-center text-[var(--color-fg-muted)] max-w-2xl mx-auto mb-10 leading-relaxed">
        An open-source meta-harness architecture. The platform manages state, security, and execution boundaries, while your agent code runs the loop.
      </p>

      <!-- Tabs Controller -->
      <div class="flex justify-center space-x-2 p-1 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-xl max-w-md mx-auto mb-10">
        <button
          id="tab-architecture"
          type="button"
          class="flex-1 py-2.5 px-4 rounded-lg text-sm font-medium transition-all duration-200 bg-[var(--color-bg-surface)] shadow-xs text-[var(--color-fg)] cursor-pointer focus:outline-none"
        >
          System Architecture
        </button>
        <button
          id="tab-lifecycle"
          type="button"
          class="flex-1 py-2.5 px-4 rounded-lg text-sm font-medium transition-all duration-200 text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] cursor-pointer focus:outline-none"
        >
          Durable Lifecycle
         <!-- Panel 1: System Architecture Diagram -->
      <div id="panel-architecture" class="space-y-12">
        <div class="relative w-full overflow-hidden border border-[var(--color-border)] rounded-2xl bg-[var(--color-bg)] p-6 md:p-10 shadow-xs">
          <!-- Dot matrix background pattern -->
          <div class="absolute inset-0 opacity-[0.03] dark:opacity-[0.07] pointer-events-none" style="background-image: radial-gradient(var(--color-fg) 1.5px, transparent 1.5px); background-size: 20px 20px;"></div>
          
          <!-- Flow layout container -->
          <div class="relative z-10 flex flex-col lg:flex-row items-center lg:items-stretch justify-between gap-6 lg:gap-2">
            
            <!-- Column 1: Client Layer -->
            <div class="w-full lg:w-[28%] flex flex-col justify-center">
              <div class="text-center lg:text-left mb-4">
                <span class="font-mono text-[10px] font-bold uppercase tracking-wider text-[var(--color-brand)] bg-[var(--color-brand-subtle)] px-2.5 py-1 rounded-full">1. Client Layer</span>
              </div>
              <div class="bg-[var(--color-bg-surface)] border border-[var(--color-border)] rounded-xl p-5 shadow-xs relative group hover:border-[var(--color-brand)] transition-all duration-300">
                <!-- Visual connector dot -->
                <div class="hidden lg:block absolute top-1/2 -right-1.5 -translate-y-1/2 w-3 h-3 rounded-full bg-[var(--color-brand)] border-2 border-[var(--color-bg)] z-20"></div>
                
                <div class="flex items-center space-x-3 mb-3">
                  <div class="p-2.5 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-lg text-[var(--color-brand)]">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="font-bold text-[var(--color-fg)] text-sm">User & Client Apps</h4>
                    <p class="text-[9px] font-mono text-[var(--color-fg-muted)]">Web UI, CLI, SDK, API</p>
                  </div>
                </div>
                <p class="text-xs text-[var(--color-fg-muted)] leading-relaxed">
                  Triggers agent execution by posting events. Connects to a real-time Server-Sent Events (SSE) stream to receive instant status updates and text chunks.
                </p>
              </div>
            </div>

            <!-- Connector Column 1 -->
            <div class="w-full lg:w-[6%] flex lg:flex-col justify-center items-center py-2 lg:py-0">
              <!-- Desktop SVG: Client -> Platform (splits into two) -->
              <svg class="hidden lg:block w-full h-40" viewBox="0 0 60 160" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M 0,80 Q 30,80 30,35 T 60,35" stroke="var(--color-border)" stroke-width="2" />
                <path d="M 0,80 Q 30,80 30,125 T 60,125" stroke="var(--color-border)" stroke-width="2" />
                
                <path d="M 0,80 Q 30,80 30,35 T 60,35" stroke="var(--color-brand)" stroke-width="2" class="animated-connector" />
                <path d="M 0,80 Q 30,80 30,125 T 60,125" stroke="var(--color-brand)" stroke-width="2" class="animated-connector" />
              </svg>
              <!-- Mobile Arrow -->
              <div class="lg:hidden flex flex-col items-center">
                <span class="text-[10px] font-mono text-[var(--color-brand)] bg-[var(--color-brand-subtle)] px-2 py-0.5 rounded mb-1">API & SSE</span>
                <svg class="w-5 h-5 text-[var(--color-brand)] animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 13l-7 7-7-7m14-6l-7 7-7-7" />
                </svg>
              </div>
            </div>

            <!-- Column 2: Platform Layer -->
            <div class="w-full lg:w-[28%] flex flex-col justify-center space-y-6 relative">
              <div class="text-center lg:text-left">
                <span class="font-mono text-[10px] font-bold uppercase tracking-wider text-[var(--color-brand)] bg-[var(--color-brand-subtle)] px-2.5 py-1 rounded-full">2. Platform Layer</span>
              </div>
              
              <!-- Session DO Card -->
              <div class="bg-[var(--color-bg-surface)] border border-[var(--color-border)] rounded-xl p-5 shadow-xs relative group hover:border-[var(--color-brand)] transition-all duration-300">
                <!-- Visual connector dots -->
                <div class="hidden lg:block absolute top-1/2 -left-1.5 -translate-y-1/2 w-3 h-3 rounded-full bg-[var(--color-brand)] border-2 border-[var(--color-bg)] z-20"></div>
                <div class="hidden lg:block absolute top-1/2 -right-1.5 -translate-y-1/2 w-3 h-3 rounded-full bg-[var(--color-brand)] border-2 border-[var(--color-bg)] z-20"></div>
                
                <div class="absolute -top-3 right-4 px-2 py-0.5 bg-[var(--color-brand)] text-[var(--color-brand-fg)] font-mono text-[8px] rounded-full uppercase font-bold tracking-wider font-semibold">
                  Durable Object
                </div>
                <div class="flex items-center space-x-3 mb-3">
                  <div class="p-2.5 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-lg text-[var(--color-brand)]">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="font-bold text-[var(--color-fg)] text-sm">Session DO & SQLite</h4>
                    <p class="text-[9px] font-mono text-[var(--color-fg-muted)]">State & Audit Store</p>
                  </div>
                </div>
                <p class="text-xs text-[var(--color-fg-muted)] leading-relaxed">
                  Maintains the append-only event log inside SQLite. Stores everything: user prompts, tool requests, logs, and outputs. Highly consistent and fully auditable.
                </p>
              </div>

              <!-- Agent Harness Card -->
              <div class="bg-[var(--color-bg-surface)] border border-[var(--color-border)] rounded-xl p-5 shadow-xs relative group hover:border-[var(--color-brand)] transition-all duration-300">
                <!-- Visual connector dots -->
                <div class="hidden lg:block absolute top-1/2 -left-1.5 -translate-y-1/2 w-3 h-3 rounded-full bg-[var(--color-brand)] border-2 border-[var(--color-bg)] z-20"></div>
                <div class="hidden lg:block absolute top-1/2 -right-1.5 -translate-y-1/2 w-3 h-3 rounded-full bg-[var(--color-brand)] border-2 border-[var(--color-bg)] z-20"></div>
                
                <div class="absolute -top-3 right-4 px-2 py-0.5 bg-[var(--color-brand-subtle)] text-[var(--color-brand)] font-mono text-[8px] rounded-full uppercase font-bold tracking-wider">
                  Loop Controller
                </div>
                <div class="flex items-center space-x-3 mb-3">
                  <div class="p-2.5 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-lg text-[var(--color-brand)]">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3 3L22 4" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="font-bold text-[var(--color-fg)] text-sm">Agent Harness</h4>
                    <p class="text-[9px] font-mono text-[var(--color-fg-muted)]">Model Loop Driver</p>
                  </div>
                </div>
                <p class="text-xs text-[var(--color-fg-muted)] leading-relaxed">
                  Compiles session history into optimized LLM prompt contexts, calls the LLM provider, parses response tokens, and schedules tool invocations.
                </p>
              </div>
            </div>

            <!-- Connector Column 2 -->
            <div class="w-full lg:w-[6%] flex lg:flex-col justify-center items-center py-2 lg:py-0">
              <!-- Desktop SVG: Platform -> Execution (distributes to three) -->
              <svg class="hidden lg:block w-full h-80" viewBox="0 0 60 320" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M 0,65 Q 30,65 30,45 T 60,45" stroke="var(--color-border)" stroke-width="2" />
                <path d="M 0,225 Q 30,225 30,160 T 60,160" stroke="var(--color-border)" stroke-width="2" />
                <path d="M 0,225 Q 30,225 30,275 T 60,275" stroke="var(--color-border)" stroke-width="2" />
                
                <path d="M 0,65 Q 30,65 30,45 T 60,45" stroke="var(--color-brand)" stroke-width="2" class="animated-connector" />
                <path d="M 0,225 Q 30,225 30,160 T 60,160" stroke="var(--color-brand)" stroke-width="2" class="animated-connector" />
                <path d="M 0,225 Q 30,225 30,275 T 60,275" stroke="var(--color-brand)" stroke-width="2" class="animated-connector" />
              </svg>
              <!-- Mobile Arrow -->
              <div class="lg:hidden flex flex-col items-center">
                <span class="text-[10px] font-mono text-[var(--color-brand)] bg-[var(--color-brand-subtle)] px-2 py-0.5 rounded mb-1">Tools & Models</span>
                <svg class="w-5 h-5 text-[var(--color-brand)] animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 13l-7 7-7-7m14-6l-7 7-7-7" />
                </svg>
              </div>
            </div>

            <!-- Column 3: Sandbox & Secure Resources -->
            <div class="w-full lg:w-[28%] flex flex-col justify-center space-y-6">
              <div class="text-center lg:text-left">
                <span class="font-mono text-[10px] font-bold uppercase tracking-wider text-[var(--color-brand)] bg-[var(--color-brand-subtle)] px-2.5 py-1 rounded-full">3. Execution & Security</span>
              </div>
              
              <!-- Sandbox Card -->
              <div class="bg-[var(--color-bg-surface)] border border-[var(--color-border)] rounded-xl p-5 shadow-xs relative group hover:border-[var(--color-brand)] transition-all duration-300">
                <!-- Visual connector dot -->
                <div class="hidden lg:block absolute top-1/2 -right-1.5 -translate-y-1/2 w-3 h-3 rounded-full bg-[var(--color-brand)] border-2 border-[var(--color-bg)] z-20"></div>
                
                <div class="flex items-center space-x-3 mb-3">
                  <div class="p-2.5 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-lg text-[var(--color-brand)]">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="font-bold text-[var(--color-fg)] text-sm">Pluggable Sandbox</h4>
                    <p class="text-[9px] font-mono text-[var(--color-fg-muted)]">Containers & VM Adapters</p>
                  </div>
                </div>
                <p class="text-xs text-[var(--color-fg-muted)] leading-relaxed">
                  Hardware-isolated runtime executing python, shell commands, and node scripts. Plugs into Cloudflare Containers, Docker, Kubernetes, E2B, or Daytona.
                </p>
              </div>

              <!-- Outbound Proxy & Vault Card -->
              <div class="bg-[var(--color-bg-surface)] border border-[var(--color-border)] rounded-xl p-5 shadow-xs relative group hover:border-[var(--color-brand)] transition-all duration-300">
                <!-- Visual connector dot -->
                <div class="hidden lg:block absolute top-1/2 -left-1.5 -translate-y-1/2 w-3 h-3 rounded-full bg-[var(--color-brand)] border-2 border-[var(--color-bg)] z-20"></div>
                
                <div class="absolute -top-3 right-4 px-2 py-0.5 bg-[var(--color-brand-subtle)] text-[var(--color-brand)] font-mono text-[8px] rounded-full uppercase font-bold tracking-wider font-semibold">
                  Zero Trust
                </div>
                <div class="flex items-center space-x-3 mb-3">
                  <div class="p-2.5 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-lg text-[var(--color-brand)]">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="font-bold text-[var(--color-fg)] text-sm">Outbound Proxy & Vault</h4>
                    <p class="text-[9px] font-mono text-[var(--color-fg-muted)]">Secure Key Injection</p>
                  </div>
                </div>
                <p class="text-xs text-[var(--color-fg-muted)] leading-relaxed">
                  Intercepts outgoing HTTPS requests from the sandbox. Injects tokens securely at the network layer. Sandboxes never have access to raw credentials.
                </p>
              </div>

              <!-- BYOK Model Gateway -->
              <div class="bg-[var(--color-bg-surface)] border border-[var(--color-border)] rounded-xl p-5 shadow-xs relative group hover:border-[var(--color-brand)] transition-all duration-300">
                <!-- Visual connector dot -->
                <div class="hidden lg:block absolute top-1/2 -left-1.5 -translate-y-1/2 w-3 h-3 rounded-full bg-[var(--color-brand)] border-2 border-[var(--color-bg)] z-20"></div>
                
                <div class="flex items-center space-x-3 mb-3">
                  <div class="p-2.5 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-lg text-[var(--color-brand)]">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="font-bold text-[var(--color-fg)] text-sm">BYOK Model Gateway</h4>
                    <p class="text-[9px] font-mono text-[var(--color-fg-muted)]">Anthropic, OpenAI, OpenRouter</p>
                  </div>
                </div>
                <p class="text-xs text-[var(--color-fg-muted)] leading-relaxed">
                  Bring Your Own Key to communicate with models. Supports model cards to customize API endpoints, system parameters, and fallback provider sequences.
                </p>
              </div>
            </div>

          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <div>
            <h3 class="font-display text-xl font-bold mb-3">Modular Seam Architecture</h3>
            <p class="text-[var(--color-fg-muted)] leading-relaxed text-sm">
              Open Managed Agents is built on clean boundaries. You write the agent's logic in the <strong>Harness</strong> layer, while the platform hosts the execution environment. The HTTP API behaves exactly like closed agent platforms, providing drop-in compatibility while giving you full source access to customize any execution block.
            </p>
          </div>
          <div>
            <h3 class="font-display text-xl font-bold mb-3">Five-line quickstart</h3>
            <p class="text-xs text-[var(--color-fg-muted)] mb-3 leading-relaxed">
              No SDK or platform account needed for local development. Launch the full environment stack locally using Docker:
            </p>
            <pre class="bg-[var(--color-bg-surface)] border border-[var(--color-border)] rounded-xl p-4 text-xs leading-relaxed overflow-x-auto font-mono text-[var(--color-fg)]"><code>git clone https://github.com/duyet/oma
cd open-managed-agents && cp .env.example .env
# Set ANTHROPIC_API_KEY in .env, then:
docker compose up -d
curl localhost:8787/v1/agents -d '&#123;"name":"hello", "model":"claude-sonnet-4-6"&#125;'</code></pre>
          </div>
        </div>

        <div class="mt-14">
          <h3 class="font-display text-xl font-bold mb-3">
            Sandbox execution is pluggable — not locked to Cloudflare Containers
          </h3>
          <p class="text-[var(--color-fg-muted)] leading-relaxed mb-4 max-w-3xl">
            Whichever harness drives the agent loop, it executes tool calls through a small, standardized <code class="font-mono text-sm">SandboxExecutor</code> interface. Cloudflare Containers is the default on the Cloudflare deployment, but adapters are already built for local subprocesses, Kubernetes pods, E2B, Daytona, and LiteBox.
          </p>
          <div class="grid md:grid-cols-2 gap-8 items-start">
            <pre class="bg-[var(--color-bg)] border border-[var(--color-border)] rounded-lg p-4 text-xs leading-relaxed overflow-x-auto"><code># Register providers dynamically — bring your own keys (BYOK)
curl -X POST /v1/sandbox_providers \
  -H 'content-type: application/json' \
  -d '&#123;
    "type": "daytona",
    "label": "My Daytona prod",
    "apiKey": "dna_...",
    "baseURL": "https://my-daytona.example.com"
  &#125;'

# List registered providers
GET /v1/sandbox_providers

# View usage stats per provider
GET /v1/sandbox_providers/:id/usage</code></pre>
            <div class="overflow-x-auto">
