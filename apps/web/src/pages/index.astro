---
import Base from "../layouts/Base.astro";
import { softwareApplicationSchema } from "../lib/seo";
import Logo from "../components/Logo.astro";
import HowItFits from "../components/HowItFits.astro";
import WiredFlows from "../components/WiredFlows.tsx";
import Icon from "../components/Icon.astro";

// SoftwareApplication is the homepage-only schema — anchors the
// "Open Managed Agents" entity in Google's knowledge graph and makes
// the page eligible for software-style rich snippets (price, license).
const schemas = [softwareApplicationSchema()];

const concepts = [
  {
    name: "Agent",
    badge: "config",
    accent: "orange" as const,
    body: "A versioned config: model, prompt, tools, skills, MCP, harness. Sessions pin a version at creation; updates never rewrite live runs.",
  },
  {
    name: "Session",
    badge: "runtime",
    accent: "blue" as const,
    body: "A conversation backed by an append-only event log. Streaming, crash recovery, and lifecycle all hang off this durable state.",
  },
  {
    name: "Environment",
    badge: "sandbox",
    accent: "green" as const,
    body: "The execution sandbox: packages, network policy, container image. Reusable across agents, so a fleet shares one runtime shape.",
  },
  {
    name: "Vault",
    badge: "secrets",
    accent: "orange" as const,
    body: "A credential store that never enters the sandbox. An outbound proxy injects tokens at the network layer, matched by URL.",
  },
];

// Deep-dive pages split off the landing page — a compact link row so the
// relocated sections stay discoverable.
const explore = [
  { title: "How it works", href: "/how-it-works/", icon: "layers", body: "The meta-harness design, architecture layers, and the durable session lifecycle." },
  { title: "Features", href: "/features/", icon: "grid", body: "Everything the platform gives you — and why it's drop-in compatible." },
  { title: "Use cases", href: "/use-cases/", icon: "workflow", body: "Real workflows: ship code, run production, answer customers, work a thread." },
  { title: "Infrastructure", href: "/infrastructure/", icon: "server", body: "Multi-agent fleets, any sandbox provider, and bridging your own machine." },
];
---

<Base
  title="oma — Open Managed Agents: self-hosted agent platform for any LLM provider and any sandbox"
  description="oma (Open Managed Agents) is an open-source, self-hostable agent platform — durable sessions, sandboxed execution, MCP tools — that runs on any LLM provider (Anthropic, OpenAI-compatible gateways, or your own model) and any sandbox platform (Cloudflare Containers, Kubernetes, E2B, Daytona, subprocess), on Cloudflare Workers or Docker."
  canonical="/"
  keywords="open managed agents, oma agent platform, self host ai agent, any llm provider agent platform, byok ai agent, claude agent sdk, mcp server host, ai agent cloudflare workers, self host claude code, claude code skills, claude managed agents alternative, claude tag alternative, open source claude tag"
  schemas={schemas}
>
  <!-- Hero -->
  {/* 69px = the fixed header's height (nav py + border in Base.astro) —
      the hero bleeds under the transparent header by exactly that much.
      If the header's height changes, this pair must change with it. */}
  <section class="relative overflow-hidden border-b border-[var(--color-border)] -mt-[69px] pt-[69px]">
    <!-- A soft iris glow bleeds in over the top; the dithered pattern now
         frames only the fit diagram below instead of the whole hero. -->
    <div class="pointer-events-none absolute inset-0 bg-[var(--color-bg)]" aria-hidden="true"></div>
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.5] dark:opacity-[0.35]"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 70% 45% at 50% -10%, color-mix(in srgb, var(--color-brand) 22%, transparent), transparent 70%);"
    ></div>
    <div class="relative max-w-5xl mx-auto px-4 py-16 md:py-20">
      <div>
        <!-- Full-width first: the Console's "How it fits together" diagram
             leads the hero — the product's mental model before the pitch. -->
        <!-- Blueprint frame around the fit diagram: a dotted measurement grid
             bounded by corner-bracket ticks (AnyRouter / Cloudflare "gateway"
             schematic language) so the diagram reads as a technical plate. -->
        <!-- Breaks out wider than the text column on large screens. -->
        <div class="mb-12 relative rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] blueprint-grid blueprint-frame p-5 md:p-10 lg:-mx-20 xl:-mx-32">
          <span class="bp-corner-bl" aria-hidden="true"></span>
          <span class="bp-corner-br" aria-hidden="true"></span>
          <div class="relative">
            <HowItFits />
          </div>
        </div>

        <!-- Pitch -->
        <div class="hero-pitch text-left">
          <h1 class="font-display text-4xl sm:text-5xl md:text-[3.1rem] lg:text-[3.4rem] font-bold tracking-tight leading-[1.07]">
            The self-hosted agent platform for
            <span
              class="hero-accent hero-rotate"
              data-rotate='["LLM provider","Sandbox"]'
              >any <span class="tw-rot">LLM provider</span><span class="typewriter-caret" aria-hidden="true"></span></span
            >
          </h1>
          <p class="mt-5 text-lg md:text-xl text-[var(--color-fg-muted)] leading-relaxed font-medium max-w-xl">
            Run your own agents on <strong class="text-[var(--color-fg)] font-semibold">any model</strong>,
            in <strong class="text-[var(--color-fg)] font-semibold">any sandbox</strong>. Deploy to Cloudflare or run
            <code class="font-mono text-base md:text-lg">docker compose up</code>.
          </p>

          <!-- Primary CTAs: repo (brand) + docs (hairline). Mirror the
               get-started section so the hero has a clear next action. -->
          <div class="hero-cta">
            <a
              href="https://github.com/duyet/oma"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-3 rounded-md bg-[var(--color-brand)] text-[var(--color-brand-fg)] font-medium font-display no-underline hover:no-underline hover:bg-[var(--color-brand-hover)] transition-colors"
              ><Icon name="download" size={16} /> Clone the repo</a
            >
            <a
              href="https://docs.oma.duyet.net"
              class="inline-flex items-center gap-2 px-5 py-3 rounded-md border border-[var(--color-border-strong)] font-medium font-display no-underline hover:no-underline hover:bg-[var(--color-bg-surface)] transition-colors"
              ><Icon name="book" size={16} /> Read the docs</a
            >
          </div>

          <!-- Proof chips: compact, scannable differentiators under the CTAs. -->
          <ul class="hero-chips">
            <li>Any&nbsp;LLM&nbsp;provider</li>
            <li>Any&nbsp;sandbox&nbsp;platform</li>
            <li>Self-hostable</li>
            <li>Apache&nbsp;2.0</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- What it is — the four primitives that carry the whole model. -->
  <section class="max-w-5xl mx-auto px-4 py-16 md:py-20" data-reveal id="what-is-oma">
    <p class="flex items-center justify-center gap-2 font-mono text-xs uppercase tracking-widest text-[var(--color-fg-subtle)] mb-3">
      <span class="section-index">01</span>
      <Icon name="box" size={14} class="text-[var(--color-brand)]" /> Product
    </p>
    <h2 class="font-display text-3xl md:text-4xl font-bold mb-4 text-center tracking-tight">
      What Open Managed Agents is
    </h2>
    <p class="text-center text-[var(--color-fg-muted)] max-w-2xl mx-auto mb-12 leading-relaxed">
      A platform for running agent fleets, not a chat UI. Four primitives
      carry the whole model.
    </p>
    <div class="grid sm:grid-cols-2 gap-5">
      {
        concepts.map((c) => (
          <article
            data-lift
            class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-6 shadow-sm hover:border-[var(--color-border-strong)]"
          >
            <div class="flex items-center justify-between gap-3 mb-3">
              <h3 class="font-display text-xl font-semibold tracking-tight">{c.name}</h3>
              <span
                class:list={[
                  "arch-badge",
                  c.accent === "blue"
                    ? "arch-badge-blue"
                    : c.accent === "green"
                      ? "arch-badge-green"
                      : "arch-badge-orange",
                ]}
              >
                {c.badge}
              </span>
            </div>
            <p class="text-sm text-[var(--color-fg-muted)] leading-relaxed">{c.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Example use case — the interactive flow demo stays on the landing page. -->
  <section class="border-y border-[var(--color-border)] bg-[var(--color-bg-surface)]" data-reveal id="example">
    <div class="max-w-5xl mx-auto px-4 py-16 md:py-20">
      <p class="flex items-center justify-center gap-2 font-mono text-xs uppercase tracking-widest text-[var(--color-fg-subtle)] mb-3">
        <span class="section-index">02</span>
      <Icon name="workflow" size={14} class="text-[var(--color-brand)]" /> Example
      </p>
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-4 text-center tracking-tight">
        See it run
      </h2>
      <p class="text-center text-[var(--color-fg-muted)] max-w-2xl mx-auto mb-12 leading-relaxed">
        Pick a use case, see its trigger → agent → result pipeline and a terminal
        demo of how to wire it — including the local bridge relay and K8s.
      </p>
      <div class="hero-visual hero-visual-band">
        <!-- Same blueprint plate as the hero diagram: a dotted measurement
             grid + corner-bracket ticks so both diagrams read as sibling
             schematics on the same technical canvas. -->
        <div class="relative w-full rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] blueprint-grid blueprint-frame p-4 shadow-sm md:p-6">
          <span class="bp-corner-bl" aria-hidden="true"></span>
          <span class="bp-corner-br" aria-hidden="true"></span>
          <div class="relative">
            <WiredFlows client:load />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Anatomy — the durable request path, drawn as a blueprint schematic in
       the same node/animated-wire vocabulary as the diagrams above. Real OMA
       architecture: session event log → harness loop → sandbox tools, with the
       vault proxy sitting off the network layer. -->
  <section class="max-w-5xl mx-auto px-4 py-16 md:py-20" data-reveal id="architecture">
    <p class="flex items-center justify-center gap-2 font-mono text-xs uppercase tracking-widest text-[var(--color-fg-subtle)] mb-3">
      <span class="section-index">03</span>
      <Icon name="layers" size={14} class="text-[var(--color-brand)]" /> Anatomy
    </p>
    <h2 class="font-display text-3xl md:text-4xl font-bold mb-4 text-center tracking-tight">
      What one request touches
    </h2>
    <p class="text-center text-[var(--color-fg-muted)] max-w-2xl mx-auto mb-12 leading-relaxed">
      Every message runs the same durable path. The session's append-only event
      log records it, the harness drives the model loop, tools execute in the
      sandbox, and the outbound proxy injects vault credentials the sandbox
      never sees.
    </p>
    <div class="relative w-full rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] blueprint-grid blueprint-frame p-5 shadow-sm md:p-8">
      <span class="bp-corner-bl" aria-hidden="true"></span>
      <span class="bp-corner-br" aria-hidden="true"></span>
      <div class="relative flex items-stretch gap-1 overflow-x-auto pb-2">
        <div class="arch-node">
          <span class="arch-node-glyph"><Icon name="workflow" size={20} /></span>
          <span class="arch-node-name">Request</span>
          <span class="arch-node-sub">user.message (SSE)</span>
        </div>
        <div class="bp-wire" aria-hidden="true"></div>
        <div class="arch-node">
          <span class="arch-node-glyph"><Icon name="layers" size={20} /></span>
          <span class="arch-node-name">Session</span>
          <span class="arch-node-sub">event log · DO-SQLite</span>
        </div>
        <div class="bp-wire" aria-hidden="true"></div>
        <div class="arch-node">
          <span class="arch-node-glyph"><Icon name="repeat" size={20} /></span>
          <span class="arch-node-name">Harness</span>
          <span class="arch-node-sub">model loop · tools</span>
        </div>
        <div class="bp-wire" aria-hidden="true"></div>
        <div class="arch-node">
          <span class="arch-node-glyph"><Icon name="box" size={20} /></span>
          <span class="arch-node-name">Sandbox</span>
          <span class="arch-node-sub">bash · read · write · MCP</span>
        </div>
        <div class="bp-wire" aria-hidden="true"></div>
        <div class="arch-node">
          <span class="arch-node-glyph"><Icon name="globe" size={20} /></span>
          <span class="arch-node-name">Vault proxy</span>
          <span class="arch-node-sub">injects creds · at network layer</span>
        </div>
      </div>
      <!-- Return-path note: the event log is what makes a crash resumable. -->
      <p class="relative mt-5 flex items-center justify-center gap-2 font-mono text-[0.62rem] uppercase tracking-widest text-[var(--color-fg-subtle)]">
        <Icon name="repeat" size={12} class="text-[var(--color-brand)]" />
        replayable event log → crash recovery &amp; resume
      </p>
    </div>
  </section>

  <!-- Explore — compact links into the deep-dive pages split off this page. -->
  <section class="max-w-5xl mx-auto px-4 py-16 md:py-20" data-reveal id="explore">
    <p class="flex items-center justify-center gap-2 font-mono text-xs uppercase tracking-widest text-[var(--color-fg-subtle)] mb-3">
      <span class="section-index">04</span>
      <Icon name="grid" size={14} class="text-[var(--color-brand)]" /> Explore
    </p>
    <h2 class="font-display text-3xl md:text-4xl font-bold mb-4 text-center tracking-tight">
      Dig deeper
    </h2>
    <p class="text-center text-[var(--color-fg-muted)] max-w-2xl mx-auto mb-12 leading-relaxed">
      The details live on their own pages — pick a thread to pull.
    </p>
    <div class="grid sm:grid-cols-2 gap-5">
      {
        explore.map((e) => (
          <a
            href={e.href}
            data-lift
            class="block rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-6 shadow-sm no-underline hover:no-underline hover:border-[var(--color-border-strong)]"
          >
            <div class="flex items-center gap-2.5 mb-2">
              <Icon name={e.icon} size={18} class="text-[var(--color-brand)]" />
              <h3 class="font-display text-lg font-semibold tracking-tight text-[var(--color-fg)]">{e.title}</h3>
              <span class="ml-auto text-[var(--color-fg-subtle)]">→</span>
            </div>
            <p class="text-sm text-[var(--color-fg-muted)] leading-relaxed">{e.body}</p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Get started -->
  <section class="border-t border-[var(--color-border)] bg-[var(--color-bg-surface)]" data-reveal id="get-started">
    <div class="max-w-3xl mx-auto px-4 py-16 md:py-20 text-center">
      <Logo size={64} class="block mx-auto mb-6 text-[var(--color-brand)]" />
      <h2 class="font-display text-3xl font-bold mb-3 tracking-tight">Get started</h2>
      <p class="text-[var(--color-fg-muted)] mb-8 leading-relaxed">
        Clone, deploy, or try the hosted deployment of the same codebase.
      </p>
      <div class="flex items-center justify-center gap-3 flex-wrap">
        <a
          href="https://github.com/duyet/oma"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-3 rounded-md bg-[var(--color-brand)] text-[var(--color-brand-fg)] font-medium font-display no-underline hover:no-underline hover:bg-[var(--color-brand-hover)] transition-colors"
          ><Icon name="download" size={16} /> Clone the repo</a
        >
        <a
          href="https://docs.oma.duyet.net"
          class="inline-flex items-center gap-2 px-5 py-3 rounded-md border border-[var(--color-border-strong)] font-medium font-display no-underline hover:no-underline hover:bg-[var(--color-bg-surface)] transition-colors"
          ><Icon name="book" size={16} /> Read the docs</a
        >
        <a
          href="https://app.oma.duyet.net/login"
          class="inline-flex items-center gap-2 px-5 py-3 rounded-md border border-[var(--color-border-strong)] font-medium font-display no-underline hover:no-underline hover:bg-[var(--color-bg-surface)] transition-colors"
          ><Icon name="server" size={16} /> Try hosted</a
        >
      </div>
    </div>
  </section>
</Base>
