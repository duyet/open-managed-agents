---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import { softwareApplicationSchema } from "../lib/seo";
import FeatureCard from "../components/FeatureCard.astro";
import BlogPostCard from "../components/BlogPostCard.astro";


const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);

function formatDate(d: Date) {
  return d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
}

// SoftwareApplication is the homepage-only schema — anchors the
// "Open Managed Agents" entity in Google's knowledge graph and makes
// the page eligible for software-style rich snippets (price, license).
const schemas = [softwareApplicationSchema()];
---

<Base
  title="oma — Open Managed Agents: self-hosted agent platform for any LLM provider"
  description="oma (Open Managed Agents) is an open-source, self-hostable agent platform — durable sessions, sandboxed execution, MCP tools — that runs on Anthropic, OpenAI-compatible gateways, or your own model, on Cloudflare Workers or Docker."
  canonical="/"
  keywords="open managed agents, oma agent platform, self host ai agent, any llm provider agent platform, byok ai agent, claude agent sdk, mcp server host, ai agent cloudflare workers, self host claude code, claude code skills, claude managed agents alternative, claude tag alternative, open source claude tag"
  schemas={schemas}
>
  <!-- Hero -->
  <section class="border-b border-[var(--color-border)]">
    <div class="max-w-5xl mx-auto px-4 py-20 md:py-28 text-center">
      <p class="text-sm font-mono uppercase tracking-wider text-[var(--color-fg-subtle)] mb-4">
        Apache 2.0 · Cloudflare-native · Self-hostable · BYOK
      </p>
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight">
        oma — the self-hosted agent platform for any LLM provider
        <span class="block mt-4 text-xl md:text-2xl text-[var(--color-fg-muted)] font-medium">
          Run your own agents — on Cloudflare or with <code class="font-mono text-base md:text-xl">docker compose up</code>
        </span>
      </h1>
      <p class="mt-6 text-base md:text-lg text-[var(--color-fg-muted)] max-w-2xl mx-auto leading-relaxed">
        An open-source, self-hostable agent platform with durable sessions, secure sandboxed execution, vault-backed credentials, and MCP server hosting. Bring Your Own Key (BYOK) for both LLM and sandboxes.
      </p>
      <div class="mt-8 flex items-center justify-center gap-3 flex-wrap">
        <a
          href="https://github.com/duyet/oma"
          target="_blank" rel="noopener noreferrer"
          class="px-5 py-3 rounded-md bg-[var(--color-fg)] text-[var(--color-bg)] font-medium"
          >★ Star on GitHub</a
        >
        <a
          href="https://app.oma.duyet.net/login"
          class="px-5 py-3 rounded-md border border-[var(--color-border)] font-medium"
          >Try the hosted version</a
        >
      </div>

    </div>
  </section>

  <!-- Why Open Managed Agents -->
  <section class="max-w-5xl mx-auto px-4 py-16" data-reveal>
    <h2 class="font-display text-3xl font-bold mb-3 text-center">Why Open Managed Agents</h2>
    <p class="text-center text-[var(--color-fg-muted)] max-w-2xl mx-auto mb-12">
      The same shape of platform you'd get from a closed vendor — sessions,
      sandboxes, tool dispatch, crash recovery, security controls — but every layer is
      inspectable, swappable, and yours to fork.
    </p>
    <div class="grid md:grid-cols-3 gap-8">
      <FeatureCard title="Drop-in compatible">
        The HTTP API mirrors the Claude Managed Agents API — same
        <code class="font-mono text-xs">/v1/agents</code>,
        <code class="font-mono text-xs">/v1/sessions</code>, same event-stream
        shape. Migrate by swapping the base URL.
      </FeatureCard>
      <FeatureCard title="Self-host on Cloudflare">
        Workers + Durable Objects + Containers + R2. One <code class="font-mono text-xs">wrangler deploy</code>,
        no servers to patch. Or run the Node + Postgres flavor on your own
        VPS if you can't be on Cloudflare.
      </FeatureCard>
      <FeatureCard title="Apache 2.0">
        Permissive license. Fork it, ship it inside your product, run a
        private fleet — no per-seat fee, no usage tax. The hosted service at
        oma.duyet.net is one deployment of the same code.
      </FeatureCard>
    </div>
  </section>

  <!-- How Open Managed Agents Works -->
  <section class="border-y border-[var(--color-border)] bg-[var(--color-bg-surface)]" data-reveal>
    <div class="max-w-5xl mx-auto px-4 py-16">
      <h2 class="font-display text-3xl font-bold mb-3 text-center">How Open Managed Agents works</h2>
      <p class="text-center text-[var(--color-fg-muted)] max-w-2xl mx-auto mb-12 leading-relaxed text-sm">
        An open-source meta-harness architecture. The platform manages state, security, and execution boundaries, while your agent code drives the loop.
      </p>

      <div class="space-y-16">
        <!-- 1. System Architecture -->
        <div>
          <h3 class="font-display text-2xl font-bold mb-6 text-center md:text-left">System Architecture</h3>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Col 1 -->
            <div class="bg-[var(--color-bg)] border border-[var(--color-border)] rounded-xl p-5 shadow-2xs">
              <span class="font-mono text-[9px] font-bold uppercase tracking-wider text-[var(--color-brand)] bg-[var(--color-brand-subtle)] px-2 py-0.5 rounded">1. Client Layer</span>
              <h4 class="font-bold text-sm text-[var(--color-fg)] mt-3 mb-2">User & Client Apps</h4>
              <p class="text-xs text-[var(--color-fg-muted)] leading-relaxed">
                Triggers agent execution by posting events. Connects to a real-time Server-Sent Events (SSE) stream to receive instant status updates and text chunks.
              </p>
            </div>
            <!-- Col 2 -->
            <div class="bg-[var(--color-bg)] border border-[var(--color-border)] rounded-xl p-5 shadow-2xs">
              <span class="font-mono text-[9px] font-bold uppercase tracking-wider text-[var(--color-brand)] bg-[var(--color-brand-subtle)] px-2 py-0.5 rounded">2. Platform Layer</span>
              <h4 class="font-bold text-sm text-[var(--color-fg)] mt-3 mb-2">Session DO & SQLite</h4>
              <p class="text-xs text-[var(--color-fg-muted)] leading-relaxed mb-3">
                Maintains the append-only event log inside SQLite. Stores everything: user prompts, tool requests, logs, and outputs.
              </p>
              <h4 class="font-bold text-sm text-[var(--color-fg)] mb-2">Agent Harness</h4>
              <p class="text-xs text-[var(--color-fg-muted)] leading-relaxed">
                Compiles session history into optimized LLM prompt contexts, calls the LLM provider, parses response tokens, and schedules tool invocations.
              </p>
            </div>
            <!-- Col 3 -->
            <div class="bg-[var(--color-bg)] border border-[var(--color-border)] rounded-xl p-5 shadow-2xs">
              <span class="font-mono text-[9px] font-bold uppercase tracking-wider text-[var(--color-brand)] bg-[var(--color-brand-subtle)] px-2 py-0.5 rounded">3. Execution & Security</span>
              <h4 class="font-bold text-sm text-[var(--color-fg)] mt-3 mb-2">Pluggable Sandbox</h4>
              <p class="text-xs text-[var(--color-fg-muted)] leading-relaxed mb-3">
                Hardware-isolated runtime executing python, shell commands, and node scripts. Plugs into Cloudflare, Kubernetes, E2B, or Daytona.
              </p>
              <h4 class="font-bold text-sm text-[var(--color-fg)] mb-2">Outbound Proxy & Vault</h4>
              <p class="text-xs text-[var(--color-fg-muted)] leading-relaxed">
                Intercepts outgoing HTTPS requests from the sandbox. Injects tokens securely at the network layer, preventing raw credential leaks.
              </p>
            </div>
          </div>
        </div>

        <!-- 2. Durable Lifecycle -->
        <div>
          <h3 class="font-display text-2xl font-bold mb-6 text-center md:text-left">Durable Lifecycle Loop</h3>
          <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
            <div class="bg-[var(--color-bg)] border border-[var(--color-border)] rounded-xl p-5 shadow-2xs">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-bold font-mono text-[var(--color-brand)]">01</span>
                <span class="text-[9px] uppercase font-mono font-bold tracking-wider text-[var(--color-fg-subtle)]">Bootstrap</span>
              </div>
              <h4 class="font-bold text-xs text-[var(--color-fg)] mb-2">Session Start</h4>
              <p class="text-[11px] text-[var(--color-fg-muted)] leading-relaxed">
                SessionDO restores the conversation log from SQLite, binds to the Agent version, and registers environment tools.
              </p>
            </div>
            
            <div class="bg-[var(--color-bg)] border border-[var(--color-border)] rounded-xl p-5 shadow-2xs">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-bold font-mono text-[var(--color-brand)]">02</span>
                <span class="text-[9px] uppercase font-mono font-bold tracking-wider text-[var(--color-fg-subtle)]">Context</span>
              </div>
              <h4 class="font-bold text-xs text-[var(--color-fg)] mb-2">Compile & Query</h4>
              <p class="text-[11px] text-[var(--color-fg-muted)] leading-relaxed">
                Harness compiles history, applies compaction rules, and queries the LLM for the next step.
              </p>
            </div>

            <div class="bg-[var(--color-bg)] border border-[var(--color-border)] rounded-xl p-5 shadow-2xs">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-bold font-mono text-[var(--color-brand)]">03</span>
                <span class="text-[9px] uppercase font-mono font-bold tracking-wider text-[var(--color-fg-subtle)]">Execute</span>
              </div>
              <h4 class="font-bold text-xs text-[var(--color-fg)] mb-2">Sandbox Run</h4>
              <p class="text-[11px] text-[var(--color-fg-muted)] leading-relaxed">
                Tool parameters are dispatched to the pluggable sandbox (executing bash scripts, editing files).
              </p>
            </div>

            <div class="bg-[var(--color-bg)] border border-[var(--color-border)] rounded-xl p-5 shadow-2xs">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-bold font-mono text-[var(--color-brand)]">04</span>
                <span class="text-[9px] uppercase font-mono font-bold tracking-wider text-[var(--color-fg-subtle)]">Proxy</span>
              </div>
              <h4 class="font-bold text-xs text-[var(--color-fg)] mb-2">Vault Injection</h4>
              <p class="text-[11px] text-[var(--color-fg-muted)] leading-relaxed">
                Outgoing requests intercept at the Proxy layer, transparently injecting secrets from the Vault.
              </p>
            </div>

            <div class="bg-[var(--color-bg)] border border-[var(--color-border)] rounded-xl p-5 shadow-2xs">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-bold font-mono text-[var(--color-brand)]">05</span>
                <span class="text-[9px] uppercase font-mono font-bold tracking-wider text-[var(--color-fg-subtle)]">Resilience</span>
              </div>
              <h4 class="font-bold text-xs text-[var(--color-fg)] mb-2">Durable Replay</h4>
              <p class="text-[11px] text-[var(--color-fg-muted)] leading-relaxed">
                If the runtime crashes, a fresh instance reads SQLite, replays the event state, and resumes execution seamlessly.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- API compatibility -->
  <section class="max-w-5xl mx-auto px-4 py-16" data-reveal>
    <h2 class="font-display text-3xl font-bold mb-4">Drop-in compatible with the Claude Managed Agents API</h2>
    <p class="text-[var(--color-fg-muted)] leading-relaxed mb-4">
      We track the public surface of the Claude Managed Agents API one-to-one.
      Resources, request shapes, response shapes, the SSE event stream — all
      the same. If your client code already speaks Managed Agents, point it at
      <code class="font-mono text-sm">https://oma.duyet.net</code> (hosted) or
      <code class="font-mono text-sm">http://localhost:8787</code> (self-host)
      and it works.
    </p>
    <p class="text-[var(--color-fg-muted)] leading-relaxed mb-4">
      What you get on top: every resource definition, every state-machine
      transition, every retry rule is in source code you can read. No black
      box. When something behaves unexpectedly, you can <em>see</em> why and
      fix it — and your fix can ship as a PR.
    </p>
    <p class="text-[var(--color-fg-muted)] leading-relaxed">
      Where the open implementation goes further: the harness layer is
      explicit and replaceable. The hosted Claude Managed Agents version owns
      the agent loop; here you can write your own. We ship a sensible default
      harness, and you swap in custom context engineering, caching, compaction,
      or tool-delivery logic without touching the platform. Read more in
      <a href="/blog/claude-managed-agents-vs-open-managed-agents/">the technical comparison</a>.
    </p>
  </section>

  <!-- Fleet operations -->
  <section class="border-t border-[var(--color-border)]" data-reveal>
    <div class="max-w-3xl mx-auto px-4 py-16 text-center">
      <h2 class="font-display text-3xl font-bold mb-4">Built for Running Multi-Agent Fleets</h2>
      <p class="text-[var(--color-fg-muted)] leading-relaxed mb-6 text-sm">
        Open Managed Agents is built from the ground up for multi-agent workloads. It provides environment-isolated sandboxes (Subprocess, E2B, Daytona, Kubernetes), a fleet-wide status board, concurrent sub-agent delegation, structured liveness heartbeats for long-running runs, and native webhook notifications (GitHub comments, Slack messages, Matrix events).
      </p>
      <a
        href="https://github.com/duyet/oma/blob/main/docs/features.md"
        class="inline-block px-5 py-2.5 rounded-md border border-[var(--color-border)] font-medium text-sm hover:bg-[var(--color-bg-surface)] transition"
      >
        Read the Fleet Features documentation →
      </a>
    </div>
  </section>

  <!-- Get started -->
  <section class="border-t border-[var(--color-border)]" data-reveal>
    <div class="max-w-3xl mx-auto px-4 py-16 text-center">
      <h2 class="font-display text-3xl font-bold mb-3">Get started</h2>

      <div class="flex items-center justify-center gap-3 flex-wrap">
        <a
          href="https://github.com/duyet/oma"
          target="_blank" rel="noopener noreferrer"
          class="px-5 py-3 rounded-md bg-[var(--color-fg)] text-[var(--color-bg)] font-medium"
          >Clone the repo</a
        >
        <a
          href="https://docs.oma.duyet.net"
          class="px-5 py-3 rounded-md border border-[var(--color-border)] font-medium"
          >Read the docs</a
        >
        <a
          href="https://app.oma.duyet.net/login"
          class="px-5 py-3 rounded-md border border-[var(--color-border)] font-medium"
          >Try hosted</a
        >
      </div>
    </div>
  </section>
</Base>
