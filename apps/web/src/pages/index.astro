---

<Base
  title="oma — Open Managed Agents: self-hosted agent platform for any LLM provider and any sandbox"
  description="oma (Open Managed Agents) is an open-source, self-hostable agent platform — durable sessions, sandboxed execution, MCP tools — that runs on any LLM provider (Anthropic, OpenAI-compatible gateways, or your own model) and any sandbox platform (Cloudflare Containers, Kubernetes, E2B, Daytona, subprocess), on Cloudflare Workers or Docker."
  canonical="/"
  keywords="open managed agents, oma agent platform, self host ai agent, any llm provider agent platform, byok ai agent, claude agent sdk, mcp server host, ai agent cloudflare workers, self host claude code, claude code skills, claude managed agents alternative, claude tag alternative, open source claude tag"
  schemas={schemas}
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-[var(--color-border)]">
    <!-- Ground: a faint hairline grid (engineering-blueprint texture) with a
         single soft iris glow bleeding from the top. Restrained, monochrome —
         no colored mesh. -->
    <div
      class="pointer-events-none absolute inset-0 opacity-70 dark:opacity-40"
      aria-hidden="true"
      style="background:
        linear-gradient(to right, var(--color-border) 1px, transparent 1px) 0 0 / 56px 56px,
        linear-gradient(to bottom, var(--color-border) 1px, transparent 1px) 0 0 / 56px 56px;
        mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, #000 30%, transparent 78%);
        -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, #000 30%, transparent 78%);"
    ></div>
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.5] dark:opacity-[0.35]"
      aria-hidden="true"
      style="background: radial-gradient(ellipse 70% 45% at 50% -10%, color-mix(in srgb, var(--color-brand) 22%, transparent), transparent 70%);"
    ></div>
    <div class="relative max-w-5xl mx-auto px-4 py-16 md:py-20">
      <div>
        <!-- Full-width first: the Console's "How it fits together" diagram
             leads the hero — the product's mental model before the pitch. -->
        <div class="mb-12">
          <HowItFits />
        </div>

        <!-- Pitch -->
        <div class="hero-pitch text-left">
          <h1 class="font-display text-4xl sm:text-5xl md:text-[3.1rem] lg:text-[3.4rem] font-bold tracking-tight leading-[1.07]">
            The self-hosted agent platform for
            <span
              class="hero-accent hero-rotate"
              data-rotate='["LLM provider","Sandbox"]'
              >any <span class="tw-rot">LLM provider</span><span class="typewriter-caret" aria-hidden="true"></span></span
            >
          </h1>
          <p class="mt-5 text-lg md:text-xl text-[var(--color-fg-muted)] leading-relaxed font-medium max-w-xl">
            Run your own agents on <strong class="text-[var(--color-fg)] font-semibold">any model</strong>,
            in <strong class="text-[var(--color-fg)] font-semibold">any sandbox</strong> — on Cloudflare or with
            <code class="font-mono text-base md:text-lg">docker compose up</code>.
          </p>

          <!-- Primary CTAs: repo (brand) + docs (hairline). Mirror the
               get-started section so the hero has a clear next action. -->
          <div class="hero-cta">
            <a
              href="https://github.com/duyet/oma"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-3 rounded-md bg-[var(--color-brand)] text-[var(--color-brand-fg)] font-medium font-display no-underline hover:no-underline hover:bg-[var(--color-brand-hover)] transition-colors"
              ><Icon name="download" size={16} /> Clone the repo</a
            >
            <a
              href="https://docs.oma.duyet.net"
              class="inline-flex items-center gap-2 px-5 py-3 rounded-md border border-[var(--color-border-strong)] font-medium font-display no-underline hover:no-underline hover:bg-[var(--color-bg-surface)] transition-colors"
              ><Icon name="book" size={16} /> Read the docs</a
            >
          </div>

          <!-- Proof chips: compact, scannable differentiators under the CTAs. -->
          <ul class="hero-chips">
            <li>Any&nbsp;LLM&nbsp;provider</li>
            <li>Any&nbsp;sandbox&nbsp;platform</li>
            <li>Self-hostable</li>
            <li>Apache&nbsp;2.0</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- Use-case flows — moved out of the hero (the fit diagram took its
       seat) but kept intact: each use case drawn as a pipeline diagram,
       trigger → agent → outputs. -->
  <section class="border-b border-[var(--color-border)]">
    <div class="max-w-5xl mx-auto px-4 py-12 md:py-14">
        <div class="hero-visual hero-visual-band">
          <div class="hero-flows-panel">
            <p class="hero-flows-head">
              <span>One agent, wired to your stack</span>
              <span class="hero-flows-legend" aria-hidden="true">trigger → agent → result</span>
            </p>
            <ul class="hero-flows">
              {heroFlows.map((f) => (
                <li class="hero-flow">
                  <div class="hero-flow-name">
                    <span>{f.name}</span>
                    {f.every && <span class="hero-flow-every">↻ {f.every}</span>}
                  </div>
                  <div class="hero-flow-pipe">
                    <span class="flow-node flow-trigger">{f.trigger}</span>
                    <span class="flow-step">
                      <svg class="flow-arrow" width="20" height="8" viewBox="0 0 20 8" aria-hidden="true">
                        <path d="M0 4h16M13 1l4 3-4 3" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
