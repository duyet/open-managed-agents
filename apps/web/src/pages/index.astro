---
import Base from "../layouts/Base.astro";
import { softwareApplicationSchema } from "../lib/seo";
import FeatureCard from "../components/FeatureCard.astro";
import Logo from "../components/Logo.astro";
import HowItFits from "../components/HowItFits.astro";
import ManagedAgentsSection from "../components/ManagedAgentsSection.astro";
import FeaturesSection from "../components/FeaturesSection.astro";
import UseCasesSection from "../components/UseCasesSection.astro";
import Icon from "../components/Icon.astro";

// SoftwareApplication is the homepage-only schema — anchors the
// "Open Managed Agents" entity in Google's knowledge graph and makes
// the page eligible for software-style rich snippets (price, license).
const schemas = [softwareApplicationSchema()];

const concepts = [
  {
    name: "Agent",
    badge: "config",
    accent: "orange" as const,
    body: "A versioned config — model, prompt, tools, skills, MCP, harness. Sessions pin a version at creation; updates never rewrite live runs.",
  },
  {
    name: "Session",
    badge: "runtime",
    accent: "blue" as const,
    body: "A conversation backed by an append-only event log. Streaming, crash recovery, and lifecycle all hang off this durable state.",
  },
  {
    name: "Environment",
    badge: "sandbox",
    accent: "green" as const,
    body: "The execution sandbox — packages, network policy, container image. Reusable across agents so a fleet shares one runtime shape.",
  },
  {
    name: "Vault",
    badge: "secrets",
    accent: "orange" as const,
    body: "A credential store that never enters the sandbox. An outbound proxy injects tokens at the network layer, per matching URL.",
  },
];

const archLayers = [
  {
    step: "01",
    title: "Client & API",
    badge: "arch-badge-orange",
    label: "Edge",
    items: [
      "HTTP API mirrors Claude Managed Agents (/v1/agents, /v1/sessions)",
      "SSE event stream for live agent.* and session.* events",
      "Console, CLI, or any client that speaks the same surface",
    ],
  },
  {
    step: "02",
    title: "Platform · SessionDO",
    badge: "arch-badge-blue",
    label: "State",
    items: [
      "Per-session Durable Object with SQLite event log",
      "Tool catalog, skills mount, sandbox binding, credential wiring",
      "Crash recovery: new harness instance rebuilds context from the log",
    ],
  },
  {
    step: "03",
    title: "Harness · model loop",
    badge: "arch-badge-green",
    label: "Policy",
    items: [
      "Decides how to drive the model: context, compaction, tool steps",
      "Default harness ships; register custom harnesses by name",
      "Prompt-cache-aware: byte-deterministic system prefix",
    ],
  },
  {
    step: "04",
    title: "Sandbox · Vault proxy",
    badge: "arch-badge-orange",
    label: "Boundary",
    items: [
      "Isolated exec for bash, files, packages (CF Containers, Docker, …)",
      "Outbound proxy injects vault secrets — never plaintext in the box",
      "MCP calls route through the platform, not the untrusted runtime",
    ],
  },
];

const lifecycle = [
  {
    n: "01",
    phase: "Bootstrap",
    title: "Session start",
    body: "SessionDO restores the event log, binds the agent version, mounts skills, and registers tools for the environment.",
  },
  {
    n: "02",
    phase: "Context",
    title: "Compile & query",
    body: "Harness builds history into a model context, applies compaction, and calls the provider (Anthropic, OpenAI-compat, or model card).",
  },
  {
    n: "03",
    phase: "Execute",
    title: "Sandbox run",
    body: "Tool calls dispatch into the sandbox — shell, read/write/edit, glob/grep, web tools — without exposing vault material.",
  },
  {
    n: "04",
    phase: "Proxy",
    title: "Vault injection",
    body: "Outbound HTTPS matches vault credentials; the proxy attaches Authorization at the network edge of the sandbox.",
  },
  {
    n: "05",
    phase: "Resilience",
    title: "Durable replay",
    body: "On crash, a fresh harness reads SQLite, emits session.error if needed, and continues from durable events — no lost turns.",
  },
];

// Hero use-case diagrams — each real agent template drawn as a small
// pipeline: what triggers it → the agent → what it produces. Reads as a
// diagram of the work, not a list of names. `every` marks scheduled runs.
const heroFlows: {
  name: string;
  trigger: string;
  outputs: string[];
  every?: string;
}[] = [
  {
    name: "Support",
    trigger: "customer asks",
    outputs: ["docs lookup", "slack reply"],
  },
  {
    name: "Incident response",
    trigger: "sentry alert",
    outputs: ["linear ticket", "slack room"],
  },
  {
    name: "Sprint retro",
    trigger: "sprint closes",
    outputs: ["retro doc"],
    every: "weekly",
  },
  {
    name: "Bug triage",
    trigger: "intercom thread",
    outputs: ["repro", "jira issue"],
  },
  {
    name: "Data analysis",
    trigger: "dataset",
    outputs: ["charts", "report"],
  },
];

// Sandbox-provider marks for the fleet band. Rendered monochrome via
// currentColor so they sit quietly in the zinc palette and pick up the iris
// brand on hover.
//
// Icon sources / licenses:
// - Cloudflare, Docker, Kubernetes, NVIDIA (OpenShell): Simple Icons
//   (https://simple-icons.org), CC0-1.0 — single-path 24-grid marks, filled
//   with currentColor.
// - Subprocess: not a brand — a terminal glyph (lucide.dev, ISC) stands in.
// - E2B: no Simple Icons entry and no clean single-path monochrome logo, so it
//   is drawn as a square-bracket glyph echoing E2B's "[ ]" wordmark.
// Sandbox-provider cards for the "any sandbox" section — label + one-liner,
// icons resolved from fleetLogos by label (fallback: box glyph).
const sandboxProviders: { label: string; logo: string; blurb: string }[] = [
  { label: "Cloudflare Sandbox", logo: "Cloudflare", blurb: "Fully managed Containers — zero setup on the CF deployment." },
  { label: "Kubernetes", logo: "Kubernetes", blurb: "Pod-per-sandbox on your cluster via the agent-sandbox controller." },
  { label: "NVIDIA OpenShell", logo: "OpenShell", blurb: "Policy-enforced agent sandboxes — default-deny egress, Landlock FS." },
  { label: "E2B", logo: "E2B", blurb: "Firecracker micro-VMs as a service — bring your API key." },
  { label: "Daytona", logo: "Daytona", blurb: "Managed cloud dev environments — bring your account." },
  { label: "Docker Compose", logo: "Docker", blurb: "Containers on any Docker host for the self-host runtime." },
  { label: "Subprocess", logo: "Subprocess", blurb: "Zero-isolation local dev — the fastest inner loop." },
  { label: "BYOK & more", logo: "", blurb: "LiteBox, BoxRun, GitHub Actions, remote agents — or register your own." },
];

const fleetLogos: { label: string; mode: "fill" | "stroke"; inner: string }[] = [
  {
    label: "Cloudflare",
    mode: "fill",
    inner: `<path d="M16.5088 16.8447c.1475-.5068.0908-.9707-.1553-1.3154-.2246-.3164-.6045-.499-1.0615-.5205l-8.6592-.1123a.1559.1559 0 0 1-.1333-.0713c-.0283-.042-.0351-.0986-.021-.1553.0278-.084.1123-.1484.2036-.1562l8.7359-.1123c1.0351-.0489 2.1601-.8868 2.5537-1.9136l.499-1.3013c.0215-.0561.0293-.1128.0147-.168-.5625-2.5463-2.835-4.4453-5.5499-4.4453-2.5039 0-4.6284 1.6177-5.3876 3.8614-.4927-.3658-1.1187-.5625-1.794-.499-1.2026.119-2.1665 1.083-2.2861 2.2856-.0283.31-.0069.6128.0635.894C1.5683 13.171 0 14.7754 0 16.752c0 .1748.0142.3515.0352.5273.0141.083.0844.1475.1689.1475h15.9814c.0909 0 .1758-.0645.2032-.1553l.12-.4268zm2.7568-5.5634c-.0771 0-.1611 0-.2383.0112-.0566 0-.1054.0415-.127.0976l-.3378 1.1744c-.1475.5068-.0918.9707.1543 1.3164.2256.3164.6055.498 1.0625.5195l1.8437.1133c.0557 0 .1055.0263.1329.0703.0283.043.0351.1074.0214.1562-.0283.084-.1132.1485-.204.1553l-1.921.1123c-1.041.0488-2.1582.8867-2.5527 1.914l-.1406.3585c-.0283.0713.0215.1416.0986.1416h6.5977c.0771 0 .1474-.0489.169-.126.1122-.4082.1757-.837.1757-1.2803 0-2.6025-2.125-4.727-4.7344-4.727"/>`,
  },
  {
    label: "Docker",
    mode: "fill",
    inner: `<path d="M13.983 11.078h2.119a.186.186 0 00.186-.185V9.006a.186.186 0 00-.186-.186h-2.119a.185.185 0 00-.185.185v1.888c0 .102.083.185.185.185m-2.954-5.43h2.118a.186.186 0 00.186-.186V3.574a.186.186 0 00-.186-.185h-2.118a.185.185 0 00-.185.185v1.888c0 .102.082.185.185.185m0 2.716h2.118a.187.187 0 00.186-.186V6.29a.186.186 0 00-.186-.185h-2.118a.185.185 0 00-.185.185v1.887c0 .102.082.185.185.186m-2.93 0h2.12a.186.186 0 00.184-.186V6.29a.185.185 0 00-.185-.185H8.1a.185.185 0 00-.185.185v1.887c0 .102.083.185.185.186m-2.964 0h2.119a.186.186 0 00.185-.186V6.29a.185.185 0 00-.185-.185H5.136a.186.186 0 00-.186.185v1.887c0 .102.084.185.186.186m5.893 2.715h2.118a.186.186 0 00.186-.185V9.006a.186.186 0 00-.186-.186h-2.118a.185.185 0 00-.185.185v1.888c0 .102.082.185.185.185m-2.93 0h2.12a.185.185 0 00.184-.185V9.006a.185.185 0 00-.184-.186h-2.12a.185.185 0 00-.184.185v1.888c0 .102.083.185.185.185m-2.964 0h2.119a.185.185 0 00.185-.185V9.006a.185.185 0 00-.184-.186h-2.12a.186.186 0 00-.186.186v1.887c0 .102.084.185.186.185m-2.92 0h2.12a.185.185 0 00.184-.185V9.006a.185.185 0 00-.184-.186h-2.12a.185.185 0 00-.184.185v1.888c0 .102.082.185.185.185M23.763 9.89c-.065-.051-.672-.51-1.954-.51-.338.001-.676.03-1.01.087-.248-1.7-1.653-2.53-1.716-2.566l-.344-.199-.226.327c-.284.438-.49.922-.612 1.43-.23.97-.09 1.882.403 2.661-.595.332-1.55.413-1.744.42H.751a.751.751 0 00-.75.748 11.376 11.376 0 00.692 4.062c.545 1.428 1.355 2.48 2.41 3.124 1.18.723 3.1 1.137 5.275 1.137.983.003 1.963-.086 2.93-.266a12.248 12.248 0 003.823-1.389c.98-.567 1.86-1.288 2.61-2.136 1.252-1.418 1.998-2.997 2.553-4.4h.221c1.372 0 2.215-.549 2.68-1.009.309-.293.55-.65.707-1.046l.098-.288Z"/>`,
