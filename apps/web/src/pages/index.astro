      <div class="mb-14">
        <h3 class="font-display text-xl font-bold mb-3">Fan out to sub-agents in parallel</h3>
        <p class="text-[var(--color-fg-muted)] leading-relaxed mb-4 max-w-3xl">
          <code class="font-mono text-sm">call_agent_*</code> tools were
          one-child-at-a-time — the parent blocked until a child reached idle
          before starting the next. Any agent with <code class="font-mono text-sm">callable_agents</code>
          configured now also gets a <code class="font-mono text-sm">call_agents_parallel</code>
          tool that fans out to several children concurrently (even the same
          sub-agent called multiple times) and aggregates results, each
          carrying its own success/failure so one bad child doesn't sink the
          batch. Concurrency defaults to 5 in-flight children, hard-capped at
          10 regardless of config — extra calls queue in waves instead of
          getting rejected.
        </p>
        <pre class="bg-[var(--color-bg)] border border-[var(--color-border)] rounded-lg p-4 text-xs leading-relaxed overflow-x-auto"><code>// call_agents_parallel input
&#123;
  "calls": [
    &#123; "agent_id": "agent_researcher", "message": "Research topic A" &#125;,
    &#123; "agent_id": "agent_researcher", "message": "Research topic B" &#125;,
    &#123; "agent_id": "agent_writer", "message": "Draft an outline for topic C" &#125;
  ]
&#125;

// result — one entry per call, independent success/failure
&#123;
  "results": [
    &#123; "agent_id": "agent_researcher", "success": true, "response": "...", "thread_id": "sthr_..." &#125;,
    &#123; "agent_id": "agent_researcher", "success": true, "response": "...", "thread_id": "sthr_..." &#125;,
    &#123; "agent_id": "agent_writer", "success": false, "error": "Sub-agent error: ..." &#125;
