---

<Base
  title="Infrastructure | Open Managed Agents"
  description="Built for multi-agent fleets: concurrent sub-agent delegation, pause & resume, any sandbox provider (Cloudflare, Kubernetes, E2B, Daytona, subprocess), and bridging your own machine over an outbound WebSocket."
  canonical="/infrastructure/"
  keywords="multi-agent fleet, agent sandbox providers, kubernetes agent sandbox, e2b daytona sandbox, bridge local machine agent, subprocess sandbox"
  schemas={schemas}
>
  <!-- Page hero -->
  <section class="border-b border-[var(--color-border)]">
    <div class="max-w-5xl mx-auto px-4 py-14 md:py-16">
      <p class="flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-[var(--color-fg-subtle)] mb-3">
        <Icon name="server" size={14} class="text-[var(--color-brand)]" /> Infrastructure
      </p>
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4 tracking-tight">
        Run fleets on any sandbox, anywhere
      </h1>
      <p class="text-lg text-[var(--color-fg-muted)] max-w-2xl leading-relaxed">
        Concurrent sub-agent delegation, liveness heartbeats, one <code class="font-mono text-base">SandboxExecutor</code>
        interface across a dozen providers — including hardware you already own.
      </p>
    </div>
  </section>

  <!-- Fleet operations -->
  <section class="border-b border-[var(--color-border)]" data-reveal id="fleets">
    <div class="max-w-5xl mx-auto px-4 py-16 md:py-20 text-center">
      <p class="flex items-center justify-center gap-2 font-mono text-xs uppercase tracking-widest text-[var(--color-fg-subtle)] mb-3">
        <Icon name="server" size={14} class="text-[var(--color-brand)]" /> Fleets
      </p>
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-4 tracking-tight">Built for multi-agent fleets</h2>
      <p class="text-[var(--color-fg-muted)] leading-relaxed mb-10 max-w-2xl mx-auto">
        Concurrent sub-agent delegation, liveness heartbeats, and native webhook
        notifications to GitHub, Slack, and Matrix.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-10 text-left">
        <article data-lift class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] p-5 hover:border-[var(--color-border-strong)]">
          <span class="arch-badge arch-badge-green mb-3">any sandbox</span>
          <h3 class="font-display text-base font-semibold mb-2 tracking-tight">Run on any sandbox</h3>
          <p class="text-sm text-[var(--color-fg-muted)] leading-relaxed">
            Cloudflare, subprocess, E2B, Daytona, or Kubernetes. One per environment,
            swappable without touching agents.
          </p>
        </article>
        <article data-lift class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] p-5 hover:border-[var(--color-border-strong)]">
          <span class="arch-badge arch-badge-orange mb-3">cost control</span>
          <h3 class="font-display text-base font-semibold mb-2 tracking-tight">Pause &amp; resume</h3>
          <p class="text-sm text-[var(--color-fg-muted)] leading-relaxed">
            Snapshot the workspace and stop the container between turns; resume
            restores it exactly, so idle agents cost nothing.
          </p>
        </article>
        <article data-lift class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] p-5 hover:border-[var(--color-border-strong)]">
          <span class="arch-badge arch-badge-blue mb-3">coding agents</span>
          <h3 class="font-display text-base font-semibold mb-2 tracking-tight">Coding agents inside</h3>
          <p class="text-sm text-[var(--color-fg-muted)] leading-relaxed">
            Run Claude Agent SDK, Grok, or any OpenAI-compatible coding agent in the
            sandbox, one Docker image per runtime.
          </p>
        </article>
        <article data-lift class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] p-5 hover:border-[var(--color-border-strong)]">
          <span class="arch-badge arch-badge-green mb-3">delegation</span>
          <h3 class="font-display text-base font-semibold mb-2 tracking-tight">Cross-sandbox sub-agents</h3>
          <p class="text-sm text-[var(--color-fg-muted)] leading-relaxed">
            Parent and child run in separate sandboxes, even on different providers,
            with parallel fan-out and result aggregation.
          </p>
        </article>
      </div>

      <!-- Sandbox-provider fleet — real brand marks, monochrome, iris on hover -->
      <div class="pixel-fleet">
        {
          fleetLogos.map((f) => (
            <figure class="group">
              <svg
                class="fleet-logo text-[var(--color-fg-subtle)] group-hover:text-[var(--color-brand)] transition-colors"
                width="30"
                height="30"
                viewBox="0 0 24 24"
                fill={f.mode === "fill" ? "currentColor" : "none"}
                stroke={f.mode === "stroke" ? "currentColor" : "none"}
                stroke-width={f.mode === "stroke" ? 1.75 : undefined}
                stroke-linecap="round"
                stroke-linejoin="round"
                role="img"
                aria-label={`${f.label} sandbox provider`}
                set:html={f.inner}
              />
              <figcaption>{f.label}</figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Any sandbox provider -->
  <section class="max-w-5xl mx-auto px-4 py-16 md:py-20" data-reveal id="sandboxes">
    <p class="flex items-center justify-center gap-2 font-mono text-xs uppercase tracking-widest text-[var(--color-fg-subtle)] mb-3">
      <Icon name="box" size={14} class="text-[var(--color-brand)]" /> Sandboxes
    </p>
    <h2 class="font-display text-3xl md:text-4xl font-bold mb-4 text-center tracking-tight">
      Connect any sandbox provider
    </h2>
    <p class="text-center text-[var(--color-fg-muted)] max-w-2xl mx-auto mb-12 leading-relaxed">
      One <code class="font-mono text-sm">SandboxExecutor</code> interface, a dozen adapters.
      Pick a provider per environment — agents and sessions never notice the difference.
    </p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {sandboxProviders.map((p) => {
        const mark = fleetLogos.find((f) => f.label === p.logo);
        return (
          <article class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] p-4 hover:border-[var(--color-border-strong)]">
            <div class="flex items-center gap-2.5 mb-2">
              {mark ? (
                <svg
                  class="w-5 h-5 shrink-0 text-[var(--color-fg-subtle)]"
                  viewBox="0 0 24 24"
                  {...(mark.mode === "fill"
                    ? { fill: "currentColor" }
                    : { fill: "none", stroke: "currentColor", "stroke-width": "2", "stroke-linecap": "round", "stroke-linejoin": "round" })}
                  aria-hidden="true"
                  set:html={mark.inner}
                />
              ) : (
                <svg class="w-5 h-5 shrink-0 text-[var(--color-fg-subtle)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/></svg>
              )}
              <h3 class="font-display text-sm font-semibold tracking-tight">{p.label}</h3>
            </div>
            <p class="text-xs text-[var(--color-fg-muted)] leading-relaxed">{p.blurb}</p>
          </article>
        );
      })}
    </div>
  </section>

  <!-- Bridge: connect your own machine -->
  <section class="border-t border-[var(--color-border)]" data-reveal id="bridge">
    <div class="max-w-5xl mx-auto px-4 py-16 md:py-20">
      <p class="flex items-center justify-center gap-2 font-mono text-xs uppercase tracking-widest text-[var(--color-fg-subtle)] mb-3">
        <Icon name="terminal" size={14} class="text-[var(--color-brand)]" /> Bridge
      </p>
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-4 text-center tracking-tight">
        Connect your own machine
      </h2>
      <p class="text-center text-[var(--color-fg-muted)] max-w-2xl mx-auto mb-12 leading-relaxed">
        One command pairs a laptop, workstation, or homelab box with your OMA
        deployment. Agents then run on hardware you already own.
      </p>

      <div class="grid lg:grid-cols-2 gap-6 items-stretch">
        <!-- CLI demo -->
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] overflow-hidden">
          <div class="flex items-center gap-1.5 px-4 py-2.5 border-b border-[var(--color-border)]">
            <span class="w-2.5 h-2.5 rounded-full bg-[var(--color-border-strong)]"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[var(--color-border-strong)]"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[var(--color-border-strong)]"></span>
            <span class="ml-2 font-mono text-[11px] text-[var(--color-fg-subtle)]">terminal</span>
          </div>
          <pre class="p-4 font-mono text-[12px] leading-relaxed overflow-x-auto"><code><span class="text-[var(--color-fg-subtle)]">$</span> npx @getoma/cli bridge setup

<span class="text-[var(--color-brand)]">⢀⣴⠶⠶⠶⠶⠶⠶⠶⠶⠶⠶⠶⠶⣦⡀
⣿⠈⠢⡀           ⣿
⣿   ⠈⠢⡀        ⣿
