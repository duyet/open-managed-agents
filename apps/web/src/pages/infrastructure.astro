---
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
import { breadcrumbSchema } from "../lib/seo";

const schemas = [
  breadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Infrastructure", path: "/infrastructure/" },
  ]),
];

// Sandbox-provider cards for the "any sandbox" section — label + one-liner,
// icons resolved from fleetLogos by label (fallback: box glyph).
const sandboxProviders: { label: string; logo: string; blurb: string }[] = [
  { label: "Cloudflare Sandbox", logo: "Cloudflare", blurb: "Fully managed Containers — zero setup on the CF deployment." },
  { label: "Kubernetes", logo: "Kubernetes", blurb: "Pod-per-sandbox on your cluster via the agent-sandbox controller." },
  { label: "NVIDIA OpenShell", logo: "OpenShell", blurb: "Policy-enforced agent sandboxes — default-deny egress, Landlock FS." },
  { label: "E2B", logo: "E2B", blurb: "Firecracker micro-VMs as a service — bring your API key." },
  { label: "Daytona", logo: "Daytona", blurb: "Managed cloud dev environments — bring your account." },
  { label: "Docker Compose", logo: "Docker", blurb: "Containers on any Docker host for the self-host runtime." },
  { label: "Subprocess", logo: "Subprocess", blurb: "Zero-isolation local dev — the fastest inner loop." },
  { label: "Browser VM", logo: "Browser", blurb: "A WASM Linux VM in your own browser tab — zero server compute." },
  { label: "BYOK & more", logo: "", blurb: "LiteBox, BoxRun, GitHub Actions, remote agents — or register your own." },
];

const fleetLogos: { label: string; mode: "fill" | "stroke"; inner: string }[] = [
