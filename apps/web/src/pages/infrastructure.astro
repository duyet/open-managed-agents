  },
  {
    label: "E2B",
    mode: "stroke",
    inner: `<path d="M9 4H5v16h4"/><path d="M15 4h4v16h-4"/>`,
  },
  {
    label: "Subprocess",
    mode: "stroke",
    inner: `<path d="m4 17 6-6-6-6"/><path d="M12 19h8"/>`,
  },
  {
    label: "Browser",
    mode: "stroke",
    inner: `<path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z"/><path d="M2 9h20"/><path d="M6 6.5h.01"/><path d="M9 6.5h.01"/>`,
