---
import Base from "../layouts/Base.astro";
import { breadcrumbSchema } from "../lib/seo";

const schemas = [
  breadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Stats", path: "/stats/" },
  ]),
];
---

<Base
  title="Stats — Open Managed Agents"
  description="Live platform stats for Open Managed Agents: agents, sessions, tasks, and CLI usage."
  canonical="/stats/"
  schemas={schemas}
>
  <section class="max-w-5xl mx-auto px-4 py-16 md:py-24">
    <p class="text-sm font-mono uppercase tracking-wider text-[var(--color-fg-subtle)] mb-4">
      Stats
    </p>
    <h1 class="font-display text-4xl sm:text-5xl font-bold tracking-tight mb-3">
      Platform stats
    </h1>
    <p class="text-lg text-[var(--color-fg-muted)] leading-relaxed mb-4 max-w-2xl">
      Live numbers pulled straight from the OMA API — no sampling, no dashboard login.
    </p>
    <p id="stats-updated" class="text-sm font-mono text-[var(--color-fg-subtle)] mb-10">
      <span class="stats-skeleton">Loading…</span>
    </p>

    <div id="stats-error" class="hidden border border-[var(--color-border)] rounded-lg bg-[var(--color-bg-surface)] p-6 text-sm text-[var(--color-fg-muted)] mb-10">
      Stats unavailable right now — please check back later.
    </div>

    <div id="stats-content" class="hidden">
      <!-- Counter tiles inside the same dithered brand frame as the hero diagram -->
      <div class="relative overflow-hidden rounded-2xl p-4 md:p-6 mb-14">
        <div
          class="pointer-events-none absolute inset-0"
          aria-hidden="true"
          style="background: url('/hero-tint.jpg') center / cover no-repeat;"
        ></div>
        <div class="relative grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
          <div class="stat-tile">
            <div class="font-mono text-3xl md:text-4xl font-bold tabular-nums" data-stat="agents-total">—</div>
            <div class="stat-label">Agents</div>
            <div class="stat-sub"><span data-stat="agents-active">—</span> active</div>
          </div>
          <div class="stat-tile">
            <div class="font-mono text-3xl md:text-4xl font-bold tabular-nums" data-stat="sessions-total">—</div>
            <div class="stat-label">Sessions</div>
            <div class="stat-sub">
              <span class="stats-pulse" aria-hidden="true"></span>
              <span data-stat="sessions-running">—</span> running
            </div>
          </div>
          <div class="stat-tile">
            <div class="font-mono text-3xl md:text-4xl font-bold tabular-nums" data-stat="tasks-total">—</div>
            <div class="stat-label">Scheduled work</div>
            <div class="stat-sub">
              <span data-stat="tasks-deployments">—</span> deployments · <span data-stat="tasks-schedules">—</span> schedules
            </div>
          </div>
          <div class="stat-tile">
            <div class="font-mono text-3xl md:text-4xl font-bold tabular-nums" data-stat="cli-total">—</div>
            <div class="stat-label">CLI commands</div>
            <div class="stat-sub">anonymous, opt-out</div>
          </div>
        </div>
      </div>

      <!-- CLI commands by name -->
      <div class="mb-14">
        <h2 class="font-display text-2xl font-bold mb-5">CLI commands by name</h2>
        <div id="stats-by-command" class="space-y-2"></div>
      </div>

      <!-- Platform breakdown -->
      <div class="mb-14">
        <h2 class="font-display text-2xl font-bold mb-5">Platform breakdown</h2>
        <div id="stats-by-platform" class="space-y-2"></div>
      </div>

      <!-- Self-hosted installs (anonymous server-side phone-home) -->
      <div>
        <h2 class="font-display text-2xl font-bold mb-5">Self-hosted installs</h2>
        <p class="text-sm text-[var(--color-fg-muted)] mb-6 max-w-2xl">
          Anonymous, opt-out aggregates reported by running OMA control planes — no names, ids, or content.
        </p>

        <div class="relative overflow-hidden rounded-2xl p-4 md:p-6 mb-10">
          <div
            class="pointer-events-none absolute inset-0"
            aria-hidden="true"
            style="background: url('/hero-tint.jpg') center / cover no-repeat;"
          ></div>
          <div class="relative grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
            <div class="stat-tile">
              <div class="font-mono text-3xl md:text-4xl font-bold tabular-nums" data-stat="installs-total">—</div>
              <div class="stat-label">Installs</div>
              <div class="stat-sub"><span data-stat="installs-active">—</span> active (7d)</div>
            </div>
            <div class="stat-tile">
              <div class="font-mono text-3xl md:text-4xl font-bold tabular-nums" data-stat="installs-sessions">—</div>
              <div class="stat-label">Sessions reported</div>
              <div class="stat-sub">across all installs</div>
            </div>
            <div class="stat-tile">
              <div class="font-mono text-3xl md:text-4xl font-bold tabular-nums" data-stat="installs-duration">—</div>
              <div class="stat-label">Avg session</div>
              <div class="stat-sub">mean duration</div>
            </div>
            <div class="stat-tile">
              <div class="font-mono text-3xl md:text-4xl font-bold tabular-nums" data-stat="installs-deployments">—</div>
              <div class="stat-label">Deployment kinds</div>
              <div class="stat-sub">mostly <span data-stat="installs-deployments-top">—</span></div>
            </div>
          </div>
        </div>

        <div class="mb-10">
          <h3 class="font-display text-xl font-bold mb-5">Sandbox launches by kind</h3>
          <div id="stats-sandbox-launches" class="space-y-2"></div>
        </div>

        <div class="mb-10">
          <h3 class="font-display text-xl font-bold mb-5">Model mix</h3>
          <div id="stats-model-mix" class="space-y-2"></div>
        </div>

        <div>
          <h3 class="font-display text-xl font-bold mb-5">Deployment kind</h3>
          <div id="stats-by-deployment-kind" class="space-y-2"></div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .stat-tile {
      border: 1px solid var(--color-border);
      border-radius: 0.75rem;
      padding: 1.1rem 1.25rem;
      background: var(--color-bg);
      transition: border-color 0.15s ease;
    }
    .stat-tile:hover {
      border-color: var(--color-border-strong);
    }
    .stat-label {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-fg-subtle);
      margin-top: 0.35rem;
    }
    .stat-sub {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.75rem;
      color: var(--color-fg-muted);
      margin-top: 0.3rem;
    }
    .stats-pulse {
      width: 0.45rem;
      height: 0.45rem;
      border-radius: 999px;
      background: var(--color-brand);
      animation: stats-pulse 2s ease-in-out infinite;
    }
    @keyframes stats-pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.35; }
    }
    .stats-skeleton {
      animation: stats-pulse 1.4s ease-in-out infinite;
    }
    /* Bars grow in on first paint. */
    :global(.stats-bar) {
      transform-origin: left;
      animation: stats-bar-grow 0.6s ease-out both;
    }
    @keyframes stats-bar-grow {
      from { transform: scaleX(0); }
      to { transform: scaleX(1); }
    }
    @media (prefers-reduced-motion: reduce) {
      .stats-pulse, .stats-skeleton, :global(.stats-bar) { animation: none; }
    }
  </style>

  <script>
    const API_BASE = "https://app.oma.duyet.net";

    function relativeTime(ms: number): string {
      const diffSec = Math.round((Date.now() - ms) / 1000);
      if (diffSec < 5) return "just now";
      if (diffSec < 60) return `${diffSec}s ago`;
      const diffMin = Math.round(diffSec / 60);
      if (diffMin < 60) return `${diffMin}m ago`;
      const diffHr = Math.round(diffMin / 60);
      if (diffHr < 24) return `${diffHr}h ago`;
      const diffDay = Math.round(diffHr / 24);
      return `${diffDay}d ago`;
    }

    function setStat(name: string, value: number | string) {
      const el = document.querySelector(`[data-stat="${name}"]`);
      if (el) el.textContent = typeof value === "number" ? value.toLocaleString() : value;
    }

    function formatDuration(ms: number): string {
      if (!ms || ms <= 0) return "—";
      const totalSec = Math.round(ms / 1000);
      if (totalSec < 60) return `${totalSec}s`;
      const min = Math.floor(totalSec / 60);
      const sec = totalSec % 60;
      if (min < 60) return sec ? `${min}m ${sec}s` : `${min}m`;
      const hr = Math.floor(min / 60);
      const remMin = min % 60;
      return remMin ? `${hr}h ${remMin}m` : `${hr}h`;
    }

    function renderBars(containerId: string, rows: Array<Record<string, unknown> & { count: number }>, key: string) {
      const container = document.getElementById(containerId);
      if (!container) return;
      if (!rows.length) {
        container.innerHTML = `<p class="text-sm text-[var(--color-fg-muted)]">No data yet.</p>`;
        return;
      }
      const max = Math.max(...rows.map((r) => r.count), 1);
      container.innerHTML = rows
        .map((row, i) => {
          const label = String(row[key] ?? "unknown");
          const pct = Math.max((row.count / max) * 100, 2);
          return `
            <div class="flex items-center gap-3 text-sm">
              <div class="w-40 shrink-0 font-mono truncate text-[var(--color-fg-muted)]" title="${label}">${label}</div>
              <div class="flex-1 h-5 bg-[var(--color-bg-surface)] rounded-sm overflow-hidden border border-[var(--color-border)]">
                <div class="stats-bar h-full rounded-sm" style="width: ${pct}%; animation-delay: ${i * 45}ms; background: color-mix(in srgb, var(--color-brand) ${i === 0 ? 100 : 65}%, var(--color-bg-surface))"></div>
              </div>
              <div class="w-14 shrink-0 text-right font-mono tabular-nums text-[var(--color-fg-subtle)]">${row.count.toLocaleString()}</div>
            </div>
          `;
        })
        .join("");
    }

    async function loadStats() {
      try {
        const res = await fetch(`${API_BASE}/v1/telemetry/stats`);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = await res.json();

        setStat("agents-total", data.agents?.total ?? 0);
        setStat("agents-active", data.agents?.active ?? 0);
        setStat("sessions-total", data.sessions?.total ?? 0);
        setStat("sessions-running", data.sessions?.running ?? 0);
        setStat("tasks-total", data.tasks?.total ?? 0);
        setStat("tasks-deployments", data.tasks?.deployments ?? 0);
        setStat("tasks-schedules", data.tasks?.schedules ?? 0);
        setStat("cli-total", data.cli?.total_commands ?? 0);

        renderBars("stats-by-command", data.cli?.by_command ?? [], "name");
        renderBars("stats-by-platform", data.cli?.by_platform ?? [], "platform");

        // Install / deployment phone-home aggregates.
        const installs = data.installs ?? {};
        setStat("installs-total", installs.total ?? 0);
        setStat("installs-active", installs.active ?? 0);
        setStat("installs-sessions", installs.sessions_reported ?? 0);
        setStat("installs-duration", formatDuration(installs.session_duration_avg_ms ?? 0));
        const kinds = installs.by_deployment_kind ?? [];
        setStat("installs-deployments", kinds.length);
        setStat("installs-deployments-top", kinds[0]?.kind ?? "—");
        renderBars("stats-sandbox-launches", installs.sandbox_launches ?? [], "kind");
        renderBars("stats-model-mix", installs.model_mix ?? [], "name");
        renderBars("stats-by-deployment-kind", kinds, "kind");

        const updatedEl = document.getElementById("stats-updated");
        if (updatedEl) {
          updatedEl.textContent = data.generated_at ? `Updated ${relativeTime(data.generated_at)} · refreshes every 60s` : "";
        }

        document.getElementById("stats-content")?.classList.remove("hidden");
        document.getElementById("stats-error")?.classList.add("hidden");
      } catch {
        document.getElementById("stats-content")?.classList.add("hidden");
        document.getElementById("stats-error")?.classList.remove("hidden");
        const updatedEl = document.getElementById("stats-updated");
        if (updatedEl) updatedEl.textContent = "";
      }
    }

    loadStats();
    setInterval(loadStats, 60_000);
  </script>
</Base>
