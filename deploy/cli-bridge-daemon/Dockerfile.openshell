# Image for the `oma bridge daemon` OpenShell backend.
#
# The default local relay works with the published npm CLI on a plain Node
# image (see deployment.yaml). The OpenShell backend, however, dynamically
# imports `@duyet/oma-sandbox` (the gRPC adapter) at runtime — an INTERNAL
# workspace package that never publishes to npm — so it must be present in
# node_modules. This image builds the CLI from the monorepo with that package
# linked. Build from the repo ROOT:
#
#   docker build -f deploy/cli-bridge-daemon/Dockerfile.openshell \
#     -t ghcr.io/duyet/oma-bridge-daemon-openshell:latest .
#
# Then point deployment.yaml's `image:` at it and drop the `command:` npx line
# (the bundled bin is on PATH as `oma`).
FROM node:22-slim AS build
RUN corepack enable
WORKDIR /app
COPY . .
RUN pnpm install --frozen-lockfile --filter @getoma/cli... \
  && pnpm --filter @getoma/cli build

FROM node:22-slim AS run
RUN corepack enable
WORKDIR /app
COPY --from=build /app /app
ENV HOME=/home/oma
# @duyet/oma-sandbox stays external in the CLI bundle and resolves from the
# workspace node_modules at runtime (its gRPC deps come along).
ENTRYPOINT ["node", "packages/cli/dist/index.js"]
CMD ["bridge", "daemon"]
