{
  "$comment": "A neutral starting token set. Swap the brand color + fonts for the user's, keep the scales. Roles (bg/surface/text/accent) let the same tokens theme light and dark. Contrast: text-on-bg and text-on-surface meet WCAG AA >= 4.5:1 in both modes.",
  "color": {
    "light": {
      "bg": "#ffffff",
      "surface": "#f5f5f4",
      "text": "#1a1a1a",
      "text-muted": "#57534e",
      "border": "#d6d3d1",
      "accent": "#2563eb",
      "accent-contrast": "#ffffff",
      "success": "#15803d",
      "warning": "#b45309",
      "danger": "#b91c1c"
    },
    "dark": {
      "bg": "#0f0f0f",
      "surface": "#1c1c1c",
      "text": "#f5f5f5",
      "text-muted": "#a1a1aa",
      "border": "#2e2e2e",
      "accent": "#60a5fa",
      "accent-contrast": "#0f0f0f",
      "success": "#4ade80",
      "warning": "#fbbf24",
      "danger": "#f87171"
    }
  },
  "font": {
    "sans": "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
    "serif": "Georgia, 'Times New Roman', serif",
    "mono": "ui-monospace, 'SF Mono', 'Cascadia Code', Menlo, monospace"
  },
  "text": {
    "$comment": "Modular scale, ratio ~1.25, base 16px. Body = base.",
    "sm": "0.8rem",
    "base": "1rem",
    "lg": "1.25rem",
    "xl": "1.563rem",
    "2xl": "1.953rem",
    "3xl": "2.441rem"
  },
  "weight": { "normal": 400, "semibold": 600, "bold": 700 },
  "leading": { "tight": 1.2, "body": 1.5 },
  "measure": "65ch",
  "space": {
    "$comment": "8px base scale. Every margin/padding/gap is a step here.",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "6": "1.5rem",
    "8": "2rem",
    "12": "3rem",
    "16": "4rem"
  },
  "radius": { "sm": "0.25rem", "base": "0.5rem", "lg": "1rem", "full": "9999px" }
}
