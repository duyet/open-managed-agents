{
  "name": "@getoma/sdk",
  "version": "0.1.1",
  "description": "Official TypeScript SDK for the oma managed agents platform. The API is also wire-compatible with @anthropic-ai/sdk via baseURL.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai",
    "agents",
    "managed-agents",
    "oma",
    "sdk",
    "llm",
    "streaming",
    "sse"
  ],
  "license": "Apache-2.0",
  "homepage": "https://oma.duyet.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/duyet/oma",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/duyet/oma/issues"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
